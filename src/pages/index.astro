---
import { getCollection } from "astro:content";
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogSorter from '../components/BlogSorter.jsx';
import { Info, GraduationCap, Rss, Contact } from "lucide-preact";
import TOC from '../components/TOC.astro';
import { PAGE_META } from '../data/page-meta';



const pageTitle = "Josh Olivier - Home";

let allPosts = await getCollection("blog");

  // Sort by date (newest first)
  allPosts = allPosts.sort(
    (a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate)
  );

const recentPosts = allPosts.slice(0, 5); // show the newest 3 blog posts by pubDate
---
<BaseLayout pageTitle={pageTitle} titleHtml="Hi, I'm Josh!" shouldCenterTitle={false} ogImage="/social-cards/home.png" description={PAGE_META.home.description}>

  <TOC />

  <p>
      I'm an incoming Psychology PhD student at the University of California, Riverside and I currently work as lab manager
      of a neuroimaging lab at the University of Texas at Dallas.
  </p>

  <p>
      I'm interested in how the brain supports episodic memory and how
      memory-related brain mechanisms are disrupted by aging and neurological conditions like Alzheimer's disease.
  </p>

<h2>Explore</h2>

<div class="explore-grid">
  <a href="/about" class="explore-card">
    <span class="explore-card-icon"><Info size="2rem" /></span>
    <span class="explore-card-title">About</span>
    <span class="explore-card-desc">My background, research interests, and what I'm up to.</span>
  </a>
  <a href="/cv" class="explore-card">
    <span class="explore-card-icon"><GraduationCap size="2rem" /></span>
    <span class="explore-card-title">CV</span>
    <span class="explore-card-desc">My academic and professional history.</span>
  </a>
  <a href="/blog" class="explore-card">
    <span class="explore-card-icon"><Rss size="2rem" /></span>
    <span class="explore-card-title">Blog</span>
    <span class="explore-card-desc">Posts on research, travel, triathlons, and 3D printing.</span>
  </a>
  <a href="/contact" class="explore-card">
    <span class="explore-card-icon"><Contact size="2rem" /></span>
    <span class="explore-card-title">Contact</span>
    <span class="explore-card-desc">Get in touch or connect with me on social media.</span>
  </a>
</div>

  <h2>Latest posts</h2>

    <BlogSorter
      posts={recentPosts}
      client:load
      showSort={false}
      showTags={false}
      showSearch={false}
      lazyLoadAll={true}
    />

    → <a href="/blog">more posts</a>

</BaseLayout>

<script>
  document.querySelectorAll('.explore-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });
</script>
