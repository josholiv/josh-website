---
import BaseLayout from "../layouts/BaseLayout.astro";
import cv from '../data/cv.json';
import '../styles/cv.css'
import Callout from '../components/Callout.astro';

const pageTitle = "Josh Olivier - CV";
const { basics, education, publications, presentations, researchExperience, grants, awards, service, affiliations, skills } = cv;

function formatDate(str: string | undefined, month: 'short' | 'long' = 'short') {
  if (!str) return '';
  const d = new Date(str);
  return `${d.toLocaleString('default', { month })} ${d.getFullYear()}`;
}

function formatDateFull(str: string | undefined) {
  if (!str) return '';
  const d = new Date(str);
  return d.toLocaleDateString('default', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatMonthYear(str: string | undefined) {
  if (!str) return '';
  const d = new Date(str);
  return d.toLocaleDateString('default', { year: 'numeric', month: 'long' });
}

function renderResponsiveDate(str: string | undefined) {
  if (!str) return '';
  return `<span class="date-short">${formatDate(str, 'short')}</span><span class="date-long">${formatDate(str, 'long')}</span>`;
}

function renderResponsiveDateRange(startDate?: string, endDate?: string) {
  if (!startDate) return '';

  const shortStart = formatDate(startDate, 'short');
  const longStart = formatDate(startDate, 'long');

  if (!endDate) {
    return `<span class="date-short">${shortStart}</span><span class="date-long">${longStart}</span>`;
  }

  const shortEnd = formatDate(endDate, 'short');
  const longEnd = formatDate(endDate, 'long');

  return `<span class="date-short">${shortStart}–${shortEnd}</span><span class="date-long">${longStart}–${longEnd}</span>`;
}

function formatStudyType(studyType: string | undefined) {
  const degreeMap: Record<string, string> = {
    BS: 'B.S.',
    BA: 'B.A.',
    MS: 'M.S.',
    MA: 'M.A.',
    PhD: 'Ph.D.'
  };

  return studyType ? degreeMap[studyType] ?? studyType : '';
}

function formatEducationSummary(ed: { studyType?: string; area?: string; startDate?: string; endDate?: string }) {
  const degree = [formatStudyType(ed.studyType), ed.area ? `in ${ed.area}` : ''].filter(Boolean).join(' ');
  const dateText = ed.endDate
    ? formatMonthYear(ed.endDate)
    : ed.startDate
      ? `Expected start ${formatMonthYear(ed.startDate)}`
      : '';

  return [degree, dateText].filter(Boolean).join(' • ');
}
---

<script>
  const printButton = document.getElementById('print-button');
  printButton?.addEventListener('click', function() {
    window.print(); 
  });
</script>

<BaseLayout pageTitle={pageTitle} shouldCenterTitle={false} shouldShowTitle={false}>

<main>
<h1 class="cv-page-title">CV</h1>

<hr class="rainbow-hr">

<Callout type="tip" >
  <span slot="title">
    To save as PDF, select <code class="btn-code">Print</code> → <code>Print as PDF</code>
  </span>
</Callout>

 <div class="cv-container">
  <button id="print-button" class="btn">Print</button>

      <h2 class="h2-cv">{basics.name}</h2>

      {/* Contact info for print version */}
      <div class="print-contact-info">
        {basics.email} • {basics.location.city}, {basics.location.region} • {basics.url}
      </div>
      
      <section>
        <div class="print-header">
        <h3 class="h3-cv">Education</h3>
        <hr />
        </div>
        {education.map(ed => (
          <div class="section-item item-entry">
            <div class="item-header">
              <div><strong>{ed.institution}</strong></div>
              <span class="date-range">{ed.location}</span>
            </div>
            <div>
            <div><i>{formatEducationSummary(ed)} {ed.score && <span>(GPA: {ed.score})</span>}</i></div> {/* show GPA only if listed in cv.json */}
            
            {ed.advisor && <div>Advisor: {ed.advisor}</div>} {/* show advisor only if listed in cv.json */}
            
            {ed.courses && ed.courses.length > 0 && ( /* show coursework only if listed in cv.json */
                <div class="indent-item"><i>Relevant coursework:</i></div> 
                <ul class="two-column-list">
                  {ed.courses.map((course) => (
                    <li>{course}</li>
                  ))}
                </ul>
            )}
            </div>
          </div>
        ))}
      </section>

      <section>
        <div class="print-header">
        <h3 class="h3-cv">Publications</h3>
        <hr />
        </div>
          <div>
            {publications.map(pub => (
              <div class="reference-entry print-section">
                <Fragment set:html={`${pub.authors.replace(/Olivier, J. M\./g, '<span class="my-name";>Olivier, J. M.</span>')}`} />
                ({pub.year}). {pub.name}. <em>{pub.publisher}</em>.

                <span class="print-only"><a href={pub.url} target="_blank" rel="noopener noreferrer">{pub.url}</a></span>

                <a href={pub.url} target="_blank" rel="noopener noreferrer" class="print-hide">
                </a>
              </div>
            ))}
          </div>
        <div class="footnote">*These authors have contributed equally to this work and share first authorship</div>
        <div class="footnote">**These authors jointly supervised this work and share senior authorship</div>
      </section>

      <section>
        <div class="print-header">
        <h3 class="h3-cv">Presentations</h3>
          <hr/>
          </div>
          <div>
            {presentations.map(pres => (
              <div class="reference-entry print-section">
                <Fragment set:html={`${pres.authors.replace(/Olivier, J. M\./g, '<span class="my-name">Olivier, J. M.</span>')}`} />
                ({pres.year}, {pres.dateRange}). <i>{pres.name}</i> [{pres.type}].
                {pres.conference}, {pres.location}.
                {pres.url && (
                  <> <a href={pres.url} target="_blank" rel="noopener noreferrer">{pres.url}</a></>
                )}
              </div>
            ))}
          </div>
        <div class="footnote">*Presenter</div>
      </section>

     <section>
      <div class="print-header">
        <h3 class="h3-cv">Research Experience</h3>
        <hr />
        </div>
        {researchExperience.map(res => (
          <div class="section-item item-entry print-section">
            <div class="item-header">
              <div><strong>{res.lab} • {res.institution}</strong></div>
              <span class="date-range">
                {res.startDate && res.endDate ? (
                  <Fragment set:html={renderResponsiveDateRange(res.startDate, res.endDate)} />
                ) : res.startDate ? (
                  <Fragment set:html={renderResponsiveDate(res.startDate)} />
                ) : ''} {/* if startDate contains a date and endDate is blank, show only the start date */}
              </span>
            </div>
            <div>
            <div><i>{res.title} • Mentor: {res.mentor}</i></div>
            </div>
            {res.duties && res.duties.length > 0 && ( /* show duties only if listed in cv.json */
                <ul>
                  {res.duties.map((duty) => (
                    <li>{duty}</li>
                  ))}
                </ul>
            )}
          </div>
        ))}
      </section>

      <section>
        <div class="print-header">
        <h3 class="h3-cv">Grants &amp; Fellowships</h3>
        <hr />
        </div>
        {grants.map(g => (
          <div class="section-item item-entry print-section">
            <div class="item-header">
              <div><strong>{g.title}</strong></div>
              <span class="date-range"><Fragment set:html={renderResponsiveDate(g.date)} /></span>
            </div>
            <div>
            {g.awarder}
            <div>{g.summary}</div>
            <div>Award: {g.award}</div>
            </div>
          </div>
        ))}
      </section>

      <section>
        <div class="print-header">
        <h3 class="h3-cv">Honors, Awards &amp; Certificates</h3>
        <hr />
        </div>
        {awards.map(a => (
          <div class="section-item item-entry print-section">
            <div class="item-header">
              <div><strong>{a.title}</strong></div>
              <span class="date-range"><Fragment set:html={renderResponsiveDate(a.date)} /></span>
            </div>
            <div>{a.awarder}
            <div>{a.summary}</div>
            </div>
          </div>
        ))}
      </section>

         <section>
    <div class="print-header">
  <h3 class="h3-cv">Skills</h3>
  <hr />
  </div>

  {/* Technical Skills */}
  <div class="skill-group print-section">
    {skills.filter(skillCategory => ["Software", "Programming"].includes(skillCategory.category)).map(skillCategory => {
      const sortedItems = [...skillCategory.items].sort((a, b) => a.localeCompare(b));

      return (
        <div class="skill-category">
          <strong>{skillCategory.category}:</strong> {sortedItems.join(", ")}
        </div>
      );
    })}
  </div>

  {/* Research Skills */}
  <div class="skill-group print-section">
    {skills.filter(skillCategory => skillCategory.category === "Neuropsychological Tests").map(skillCategory => {
      const sortedItems = [...skillCategory.items].sort((a, b) => a.localeCompare(b));

      return (
        <div class="skill-category">
          <div><strong>Neuropsychological Tests:</strong> {sortedItems.join(", ")}</div>
        </div>
      );
    })}
  </div>
</section>

      <section>
        <div class="print-header">
          <h3 class="h3-cv">Service, Work &amp; Activities</h3>
         <hr />
        </div>
        {service.map(s => (
          <div class="section-item item-entry print-section">
            <div class="item-header">
              <div><strong>{s.title}</strong></div>
              <span class="date-range">
                {s.startDate && s.endDate ? (
                  <Fragment set:html={renderResponsiveDateRange(s.startDate, s.endDate)} />
                ) : s.startDate ? (
                  <Fragment set:html={renderResponsiveDate(s.startDate)} />
                ) : ''} {/* if startDate contains a date and endDate is blank, show only the start date */}
              </span>
            </div>
            <div>{s.organization}
            <div>{s.summary}</div>
            </div>
          </div>
        ))}
      </section>

      <section>
        <div class="print-header">
        <h3 class="h3-cv">Professional Affiliations</h3>
        <hr />
        </div>
        {affiliations.map(aff => (
          aff.organization.map(org => (
            <div>{org}</div>
          ))
        ))}
      </section> 

    </div>
  </body>
</html>
</main>
</BaseLayout>