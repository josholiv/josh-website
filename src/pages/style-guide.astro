---
import BaseLayout from '../layouts/BaseLayout.astro';
import Callout from '../components/Callout.astro';
import Dropdown from '../components/Dropdown.astro';
import TOC from '../components/TOC.astro';
import { Bike, Cog as CogIcon, Dna, Rss, Code as CodeIcon, Map as MapIcon, SportShoe } from "lucide-preact";

const isDev = import.meta.env.DEV;
if (!isDev) return Astro.redirect('/404');
---

<BaseLayout pageTitle="Style Guide" shouldCenterTitle={false} shouldShowTitle={false}>

  <h1>Style Guide <span class="title-muted">/ dev only</span></h1>

  <hr class="rainbow-hr">

<TOC />

  <!-- ─── Typography ─── -->
  <h2>Typography</h2>

  <h1>Heading 1 — DM Serif Text</h1>
  <h2>Heading 2 — DM Serif Text</h2>
  <h3>Heading 3 — Noto Sans</h3>
  <h4>Heading 4 — Noto Sans</h4>
  <h5>Heading 5 — Noto Sans</h5>
  <h6>Heading 6 — Noto Sans</h6>
  <p>Body text — Noto Sans. The quick brown fox jumps over the lazy dog. <strong>Bold text.</strong> <em>Italic text.</em> <strong><em>Bold italic.</em></strong></p>
  <p>A paragraph with an <a href="#">inline link</a> and an <a href="https://example.com" target="_blank">external link</a> (should show external link icon).</p>
  <p class="title-muted">Muted text using <code>.title-muted</code></p>

  <hr />

  <!-- ─── Code ─── -->
  <h2>Inline Code</h2>
  <p>Use <code>const x = 1</code> for inline code. Or reference a class like <code>.post-wrapper</code>.</p>

  <hr />

  <!-- ─── Buttons ─── -->
  <h2>Buttons</h2>
  <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
    <button class="btn">Default Button</button>
    <button class="btn icon-container-inline">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
      With Icon
    </button>
    <Dropdown options={['Option A', 'Option B', 'Option C']} />
  </div>

  <hr />

  <!-- ─── Tags ─── -->
  <h2>Tags</h2>
  <p>Clickable tags (used in tag sidebar):</p>
  <div class="tags">
    <span class="tag tag-theme-3dprinting"><CogIcon size="0.9rem" class="tag-icon" /> <span>3Dprinting</span></span>
    <span class="tag tag-theme-science"><Dna size="0.9rem" class="tag-icon" /> <span>science</span></span>
    <span class="tag tag-theme-blog active"><Rss size="0.9rem" class="tag-icon" /> <span>blog</span></span>
    <span class="tag tag-theme-code"><CodeIcon size="0.9rem" class="tag-icon" /> <span>code</span></span>
  </div>

  <p>Display-only tags (used on blog post cards):</p>
  <div class="tags">
    <span class="tag-blogsorter tag-theme-travel"><MapIcon size="0.9rem" class="tag-icon" /> <span>travel</span></span>
    <span class="tag-blogsorter tag-theme-triathlon"><SportShoe size="0.9rem" class="tag-icon" /> <span>triathlon</span></span>
    <span class="tag-blogsorter tag-theme-code"><CodeIcon size="0.9rem" class="tag-icon" /> <span>code</span></span>
  </div>

  <p>Tags with counts (used in tag sidebar):</p>
  <div class="tags">
    <span class="tag tag-theme-3dprinting"><CogIcon size="0.9rem" class="tag-icon" /> <span>3Dprinting</span> <span class="tag-count">(4)</span></span>
    <span class="tag tag-theme-science"><Dna size="0.9rem" class="tag-icon" /> <span>science</span> <span class="tag-count">(12)</span></span>
    <span class="tag tag-theme-travel"><MapIcon size="0.9rem" class="tag-icon" /> <span>travel</span> <span class="tag-count">(3)</span></span>
  </div>

  <hr />

  <!-- ─── Blockquote ─── -->
  <h2>Blockquote</h2>
  <div class="blockquote">
    This is a plain blockquote. It has no background color and uses <code>var(--bg-secondary)</code> 
    as its left border color.
  </div>

  <div class="blockquote">
    If I make the text inside the blockquote really long, it should wrap and the blockquote should expand vertically to fit the content. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec a diam lectus. Sed sit amet ipsum mauris. Maecenas congue ligula ac quam viverra nec consectetur ante hendrerit. Donec et mollis dolor.
  </div>

  <hr />

  <!-- ─── Callouts ─── -->
    <h2>Callouts</h2>

  <Callout type="note">
    This is a <strong>note</strong> callout. Use it for supplementary information or asides.
  </Callout>

  <Callout type="example">
    This is an <strong>example</strong> callout. Useful for illustrating concepts with sample content.
  </Callout>

  <Callout type="info">
    This is an <strong>info</strong> callout. Use it for general information or context. Has a link: <a href="#">click here</a>.
  </Callout>

  <Callout type="todo">
    This is a <strong>todo</strong> callout. Use it for action items embedded in notes.
  </Callout>

  <Callout type="tip">
    This is a <strong>tip</strong> callout. Use it for helpful hints or best practices.
  </Callout>

  <Callout type="hint">
    This is a <strong>hint</strong> callout. An alias for tip.
  </Callout>

  <Callout type="important">
    This is an <strong>important</strong> callout. Another alias for tip.
  </Callout>

  <Callout type="success">
    This is a <strong>success</strong> callout. Use it to confirm something worked or highlight a positive outcome.
  </Callout>

  <Callout type="check">
    This is a <strong>check</strong> callout. An alias for success.
  </Callout>

  <Callout type="done">
    This is a <strong>done</strong> callout. An alias for success.
  </Callout>

  <Callout type="warning">
    This is a <strong>warning</strong> callout. Use it to flag something the reader should be cautious about.
  </Callout>

  <Callout type="caution">
    This is a <strong>caution</strong> callout. An alias for warning.
  </Callout>

  <Callout type="attention">
    This is an <strong>attention</strong> callout. An alias for warning.
  </Callout>

  <Callout type="faq">
    This is a <strong>faq</strong> callout. Good for anticipated questions.
  </Callout>

  <Callout type="question">
    This is a <strong>question</strong> callout. An alias for faq.
  </Callout>

  <Callout type="help">
    This is a <strong>help</strong> callout. An alias for faq.
  </Callout>

  <Callout type="danger">
    This is a <strong>danger</strong> callout. Reserved for serious errors or destructive actions.
  </Callout>

  <Callout type="error">
    This is an <strong>error</strong> callout. An alias for danger.
  </Callout>

  <Callout type="bug">
    This is a <strong>bug</strong> callout. Useful for known issues in documentation.
  </Callout>

  <Callout type="failure">
    This is a <strong>failure</strong> callout. An alias for danger.
  </Callout>

  <Callout type="fail">
    This is a <strong>fail</strong> callout. An alias for danger.
  </Callout>

  <Callout type="missing">
    This is a <strong>missing</strong> callout. An alias for danger.
  </Callout>

  <Callout type="quote">
    This is a <strong>quote</strong> callout. Matches your blockquote style with a neutral border.
  </Callout>

  <Callout type="cite">
    This is a <strong>cite</strong> callout. An alias for quote.
  </Callout>

  <Callout type="code">
    This is a <strong>code</strong> callout. It uses the neutral gray treatment like quote, but with a code icon.
  </Callout>

  <Callout type="abstract">
    This is an <strong>abstract</strong> callout. Good for summaries at the top of long notes.
  </Callout>

  <Callout type="summary">
    This is a <strong>summary</strong> callout. An alias for abstract.
  </Callout>

  <Callout type="tldr">
    This is a <strong>tldr</strong> callout. An alias for abstract.
  </Callout>

  <hr />

  <h2>Customizing callouts</h2>

   <h3>Collapsible callouts</h3>

  <Callout type="note" collapsible defaultOpen={true}>
    This is a collapsible callout. It's set to be open using <code>defaultOpen={true}</code>.
  </Callout>

  <Callout type="warning" collapsible>
    This one starts collapsed, which is the default behavior when using the <code>collapsible</code> prop without specifying <code>defaultOpen</code>.
  </Callout>

  <h3>Custom titles, icons, and more</h3>

  <Callout type="info" title={`Custom callout`} icon={Bike}>
    This is a customized callout. I overrode the default title and icon of the <code>info</code> callout with custom properties.
  </Callout>

  <Callout type="note"> 
    <span slot="title">
      Check out my <a href="/about">about page</a>
    </span>
    This callout has a linked title using the named title slot.
  </Callout>

  <Callout type="tip" title={`You can also create a callout with just a title`}></Callout>

  <hr />

  <!-- ─── Rainbow Divider ─── -->
  <h2>Rainbow Divider</h2>
  <hr class="rainbow-hr">

  <hr>

  <!-- ─── Wave Divider ─── -->
  <h2>Wave Divider</h2>
  <div class="wave-container">
    <div class="wave wave-small"></div>
    <div class="wave wave-big"></div>
  </div>

  <hr />

  <!-- ─── Lists ─── -->
  <h2>Lists</h2>
  <ul>
    <li>Unordered list item one</li>
    <li>Unordered list item two</li>
    <li>Unordered list item three</li>
  </ul>
  <ol>
    <li>Ordered list item one</li>
    <li>Ordered list item two</li>
    <li>Ordered list item three</li>
  </ol>

  <hr />

  <!-- ─── Color Palette ─── -->
  <h2>Color Palette</h2>

  {[
    { name: 'blue',    shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'green',   shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'orange',  shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'red',     shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'pink',    shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'purple',  shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'cyan',    shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
    { name: 'neutral', shades: ['050','100','200','300','400','500','600','700','800','900','950'] },
  ].map(({ name, shades }) => (
    <div style="margin-bottom: 0.75rem;">
      <p style="margin: 0 0 0.35rem; font-family: 'Atkinson Hyperlegible Mono', monospace; font-size: 0.85rem;">{name}</p>
      <div style="display: flex; gap: 2px;">
        {shades.map(shade => (
          <div
            title={`--${name}-${shade}`}
            style={`background-color: var(--${name}-${shade}); width: 2rem; height: 2rem; border-radius: 2px; flex-shrink: 0;`}
          />
        ))}
      </div>
    </div>
  ))}

  <hr />

  <!-- ─── Theme Tokens ─── -->
  <h2>Theme Tokens</h2>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
    {[
      'bg-primary', 'bg-secondary', 'bg-border',
      'text-normal', 'text-muted', 'text-faint', 'text-heading', 'text-on-accent',
      'accent', 'accent-hover', 'link-color', 'link-color-hover',
      'code-bg', 'code-text', 'code-border',
      'btn-text', 'btn-text-hover',
    ].map(token => (
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <div style={`background-color: var(--${token}); width: 1.5rem; height: 1.5rem; border-radius: 2px; border: 1px solid var(--bg-border); flex-shrink: 0;`} />
        <code>--{token}</code>
      </div>
    ))}
  </div>

</BaseLayout>