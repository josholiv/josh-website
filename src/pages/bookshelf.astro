    <div class="stat-card">
      <span class="stat-card-icon"><Users size="1.5rem" /></span>
      <span class="stat-card-number">{totalAuthors}</span>
      <span class="stat-card-label">authors read</span>
    </div>
    {avgPages !== null && (
      <div class="stat-card">
        <span class="stat-card-icon"><ScrollText size="1.5rem" /></span>
        <span class="stat-card-number">{avgPages.toLocaleString()}</span>
        <span class="stat-card-label">avg page length</span>
      </div>
    )}
  </div>

  <div class="stats-charts">
