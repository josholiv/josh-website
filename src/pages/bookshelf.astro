      <p class="chart-title">Books per year</p>
      <div class="year-bars">
        {booksPerYear.map(({ year, count }) => (
          <div class="year-bar-col">
            <span class="bar-count">{count}</span>
            <div class="year-bar" style={`height: ${(count / maxBooksYear) * 100}%`}></div>
            <span class="bar-label">{year}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="chart-section">
      <p class="chart-title">Rating distribution</p>
      <div class="rating-bars">
        {ratingDistArr.map(({ star, count }) => (
          <div class="rating-row">
            <span class="rating-label">{'★'.repeat(star)}</span>
            <div class="rating-bar-track">
              <div class="rating-bar-fill" style={`width: ${(count / maxRatingCount) * 100}%`}></div>
            </div>
            <span class="rating-count">{count}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  {pageCounts.length >= 4 && (
    <div class="stats-charts">
      <div class="chart-section chart-section-wide">
        <p class="chart-title">Page count distribution</p>
        <svg viewBox={`0 0 ${RC_SVG_W} ${RC_SVG_H}`} preserveAspectRatio="none" class="raincloud-svg" role="img" aria-label="Raincloud plot of page counts per book" data-rc-info={rcJsData}>
          <defs>
            <clipPath id="rc-pages-clip">
              <rect x={RC_PAD_L} y={0} width={RC_PLOT_W} height={RC_AXIS_Y - 1} />
            </clipPath>
          </defs>
          <!-- Clipped data layer -->
          <g clip-path="url(#rc-pages-clip)">
            <path d={rcPathD} class="rc-cloud" />
            <line x1={rcWhiskerLoX} y1={RC_BOX_Y + RC_BOX_H / 2} x2={rcBoxX1} y2={RC_BOX_Y + RC_BOX_H / 2} class="rc-whisker" stroke-linecap="round" />
            <line x1={rcBoxX2} y1={RC_BOX_Y + RC_BOX_H / 2} x2={rcWhiskerHiX} y2={RC_BOX_Y + RC_BOX_H / 2} class="rc-whisker" stroke-linecap="round" />
            <line x1={rcWhiskerLoX} y1={RC_BOX_Y + 3} x2={rcWhiskerLoX} y2={RC_BOX_Y + RC_BOX_H - 3} class="rc-whisker" />
            <line x1={rcWhiskerHiX} y1={RC_BOX_Y + 3} x2={rcWhiskerHiX} y2={RC_BOX_Y + RC_BOX_H - 3} class="rc-whisker" />
            <rect x={rcBoxX1} y={RC_BOX_Y} width={Math.max(rcBoxX2 - rcBoxX1, 2)} height={RC_BOX_H} class="rc-box" />
            <line x1={rcMedianX} y1={RC_BOX_Y} x2={rcMedianX} y2={RC_BOX_Y + RC_BOX_H} class="rc-median" />
            <rect x={rcWhiskerLoX} y={RC_BOX_Y} width={Math.max(rcWhiskerHiX - rcWhiskerLoX, 4)} height={RC_BOX_H} class="rc-bw-hit" />
            {rcDots.map(dot => (
              <circle cx={dot.cx} cy={dot.cy} r="6" class={dot.outlier ? 'rc-dot rc-outlier' : 'rc-dot'} />
            ))}
          </g>
          <!-- Axis layer (unclipped) -->
          <line x1={RC_PAD_L} y1={RC_AXIS_Y} x2={RC_SVG_W - RC_PAD_R} y2={RC_AXIS_Y} class="rc-axis" />
          <g class="rc-ticks-container">
            {rcTicks.map((t, i) => (
              <g class="rc-tick-group" data-tick-i={i}>
                <line x1={t.x} y1={RC_AXIS_Y} x2={t.x} y2={RC_AXIS_Y + 4} class="rc-tick" />
