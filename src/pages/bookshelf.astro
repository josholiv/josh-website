---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hardcover from '../components/Hardcover.js';
import Dropdown from '../components/Dropdown.jsx';
import { getCollection } from 'astro:content';
import { env } from 'cloudflare:workers';
import { ExternalLink } from "lucide-preact";

let books = [];
let fetchError;

const allPosts = await getCollection('blog');
const reviewMap = new Map();
for (const post of allPosts) {
  if (post.data.tags?.includes('books') && post.data.bookTitle) {
    reviewMap.set(post.data.bookTitle.toLowerCase(), `/posts/${post.id}/`);
  }
}

try {
  const hc = new Hardcover(env);
  const result = await hc.fetch();
  books = (result.userBooks || []).map(entry => ({
    title: entry.book?.title || "Untitled",
    cover: entry.book?.image?.url || null,
    rating: entry.rating ?? null,
    lastRead: entry.last_read_date ?? null,
    authors: (entry.book?.contributions || [])
      .map(c => c.author?.name)
      .filter(Boolean)
      .join(", "),
    reviewUrl: reviewMap.get((entry.book?.title || '').toLowerCase()) || null,
    hardcoverUrl: entry.book?.slug ? `https://hardcover.app/books/${entry.book.slug}` : null,
  })).sort((a, b) => new Date(b.lastRead) - new Date(a.lastRead));
} catch (e) {
  fetchError = e.message;
}
---

<BaseLayout pageTitle="Bookshelf" shouldCenterTitle={false} shouldShowTitle={false}>

  <h1>Bookshelf</h1>
  <hr class="rainbow-hr">

  {fetchError && <p style="color: red;">Error: {fetchError}</p>}

  <!-- search + rating filter -->
  <div style="display: flex; gap: 0.75rem; align-items: center; margin-top: 1rem; flex-wrap: wrap; justify-content: space-between;">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <div style="position: relative;">
        <input
          type="text"
          placeholder="Search..."
          class="book-search"
          id="bookSearch"
        />
        <kbd class="search-hint">/</kbd>
      </div>
      <p class="book-count" id="bookCount" style="margin: 0; white-space: nowrap;"></p>
    </div>

    <div style="display: flex; gap: 0.75rem; flex-shrink: 0; align-items: center;">
      <button class="btn" id="reviewFilterBtn" aria-pressed="false">Has review</button>
      <Dropdown
        client:load
        options={['★ — ★★★★★', '★★★★★', '★★★★', '★★★', '★★', '★', 'Not rated']}
        defaultOption="★ — ★★★★★"
      />
    </div>
  </div>

  <div class="book-grid">
    {books.map(book => (
      <div class="book-card" data-rating={book.rating ?? 'none'} data-has-review={book.reviewUrl ? 'true' : 'false'}>
        <div class="cover-area">
          <div class="cover-wrap">
            {book.cover
              ? (
                <a href={book.hardcoverUrl || '#'} class="cover-hover-wrap" target="_blank" rel="noopener noreferrer" aria-label={`View ${book.title} on Hardcover`}>
                  <img src={book.cover} alt={book.title} class="cover-img" />
                  <div class="cover-overlay">
                    <img src={book.cover} alt="" class="cover-bg-blur" aria-hidden="true" />
                    <div class="cover-overlay-text">
                      <span class="placeholder-title">{book.title}</span>
                      <i class="placeholder-author">{book.authors}</i>
                    </div>
                  </div>
                </a>
              )
              : (
                <div class="cover-placeholder">
                  <span class="placeholder-title">{book.title}</span>
                  <i class="placeholder-author">{book.authors}</i>
                </div>
              )
            }
          </div>
          {book.hardcoverUrl && (
            <a href={book.hardcoverUrl} class="hardcover-badge" target="_blank" rel="noopener noreferrer" aria-label={`View ${book.title} on Hardcover`}>View on Hardcover <ExternalLink size={10}/></a>
          )}
        </div>

        <!-- Hidden but searchable -->
        <p class="book-title">{book.title}</p>
        <p class="book-author">{book.authors}</p>

        <div class="stars">
          {book.rating !== null
            ? Array.from({ length: 5 }).map((_, i) => {
                const filled = i < Math.floor(book.rating);
                const half =
                  !filled &&
                  (book.rating - Math.floor(book.rating)) >= 0.5 &&
                  i === Math.floor(book.rating);

                return (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill={filled ? 'currentColor' : half ? 'url(#half-fill)' : 'none'}
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class={`star ${filled ? 'filled' : half ? 'half' : 'empty'}`}
                  >
                    <defs>
                      <linearGradient id="half-fill">
                        <stop offset="50%" stop-color="currentColor"/>
                        <stop offset="50%" stop-color="transparent"/>
                      </linearGradient>
                    </defs>
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                );
              })
            : <span class="no-rating">not rated</span>
          }
        </div>

        {book.reviewUrl && (
          <a href={book.reviewUrl} class="tag-blogsorter tag-theme-books review-badge">see review</a>
        )}

        {book.lastRead && (
          <p class="book-year">
            {new Date(book.lastRead).getFullYear()}
          </p>
        )}

      </div>
    ))}
  </div>

</BaseLayout>

<style>
  .book-search {
    height: 2.25rem;
    padding: 0.5rem 0.75rem;
    border-radius: 10px;
    border: none;
    background: var(--bg-secondary);
    color: var(--text-normal);
    font-size: 0.9rem;
    font-family: "Atkinson Hyperlegible Mono", monospace;
    box-shadow: none;
    outline: none;
    max-width: 28rem;
    width: 100%;
  }

  .book-search::placeholder {
    color: var(--text-faint);
  }

  .book-search:focus {
    box-shadow: 0 2px 0 0 var(--btn-text-hover);
  }

  .search-hint {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: "Atkinson Hyperlegible Mono", monospace;
    font-size: 0.75rem;
    color: var(--text-faint);
    background: var(--bg-primary);
    border: 1px solid var(--bg-border);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    pointer-events: none;
    line-height: 1.4;
  }

  .book-count {
    font-size: 0.8rem;
    color: var(--text-faint);
    margin: 1rem 0 0 0;
    font-family: "Atkinson Hyperlegible Mono", monospace;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .cover-area {
    position: relative;
    width: 100%;
  }

  .cover-wrap {
    width: 100%;
    aspect-ratio: 2 / 3;
    border-radius: 2px;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .cover-area:hover .cover-wrap {
    box-shadow: 0 0 0 2px var(--purple-600);
  }

    html:not(.dark) .cover-area:hover .cover-wrap {
    box-shadow: 0 0 0 2px var(--purple-500);
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--bg-secondary);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    padding: 0.5rem;
    text-align: left;
    color: var(--text-muted);
  }

  .placeholder-title {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .placeholder-author {
    font-size: 0.75rem;
    font-style: italic;
    color: var(--text-normal);
  }

  .cover-hover-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .cover-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
    overflow: hidden;
  }

  .cover-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.5) 100%
    );
    z-index: 1;
  }

  .cover-hover-wrap:hover .cover-overlay {
    opacity: 1;
  }

  .cover-bg-blur {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(8px) brightness(0.5);
    transform: scale(1.5);
    z-index: 0;
  }

  .cover-overlay-text {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.5rem;
  }

  .cover-overlay-text .placeholder-title {
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
  }

  .cover-overlay-text .placeholder-author {
    color: rgba(255, 255, 255, 0.7);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
  }

  .hardcover-badge {
    position: absolute;
    top: 100%;
    left: -2px;
    right: -2px;
    z-index: 10;
    background: var(--purple-600);
    color: var(--purple-050);
    font-size: 0.65rem;
    font-family: "Atkinson Hyperlegible Mono", monospace;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.25rem 0.5rem;
    border-radius: 0 0 7px 7px;
    letter-spacing: 0.03em;
    opacity: 0;
    transform: translateY(-5px);
    transition: opacity 0s ease, transform 0.2s ease;
    cursor: pointer;
    text-decoration: none;
  }

  a.hardcover-badge::after {
    display: none;
  }

  html:not(.dark) .hardcover-badge {
    background: var(--purple-500);
    color: var(--purple-950);
  }

  .cover-area:hover .hardcover-badge {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hidden but searchable */
  .book-title,
  .book-author {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .book-year {
    font-size: 0.7rem;
    color: var(--text-faint);
    margin: 0;
  }

  .stars {
    display: flex;
    gap: 1px;
  }

  .star.filled,
  .star.half {
    color: var(--text-muted);
  }

  .star.empty {
    color: var(--text-faint);
  }

  .no-rating {
    font-size: 0.65rem;
    color: var(--text-faint);
    font-style: italic;
  }

  .review-badge {
    font-size: 0.7rem;
    margin-top: 0.3rem;
    text-decoration: none;
    padding: 0.2rem 0.5rem;
  }

  #reviewFilterBtn.active {
    background-color: var(--pink-700);
    color: var(--pink-050);
    box-shadow: 0 2px 0 0 var(--pink-400);
  }

  html:not(.dark) #reviewFilterBtn.active {
    background-color: var(--pink-100);
    color: var(--pink-700);
    box-shadow: 0 2px 0 0 var(--pink-300);
  }

  .cover-hover-wrap {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* suppress the global a[target="_blank"]::after icon inside the cover */
  a.cover-hover-wrap::after {
    display: none;
  }
</style>

<script>
  const searchInput = document.getElementById('bookSearch');
  const searchHint = document.querySelector('.search-hint');
  const bookCount = document.getElementById('bookCount');
  const books = Array.from(document.querySelectorAll('.book-card'));
  const reviewFilterBtn = document.getElementById('reviewFilterBtn');
  let currentRating = 'all';
  let filterReview = false;

  const ratingMap = {
    '★ — ★★★★★': 'all',
    '★★★★★': '5',
    '★★★★': '4',
    '★★★': '3',
    '★★': '2',
    '★': '1',
    'Not rated': 'unrated',
  };

  function updateCount() {
    const visible = books.filter(b => b.style.display !== 'none').length;
    bookCount.textContent = `${visible} of ${books.length} books`;
  }

  function filterBooks() {
    const query = searchInput.value.toLowerCase();

    books.forEach(book => {
      const title = book.querySelector('.book-title')?.textContent.toLowerCase() || '';
      const author = book.querySelector('.book-author')?.textContent.toLowerCase() || '';
      const year = book.querySelector('.book-year')?.textContent || '';
      const ratingAttr = book.dataset.rating;
      const hasReview = book.dataset.hasReview === 'true';

      const matchesSearch = title.includes(query) || author.includes(query) || year.includes(query);

      let matchesRating = true;
      if (currentRating === 'unrated') {
        matchesRating = ratingAttr === 'none';
      } else if (currentRating !== 'all') {
        const bookRating = parseFloat(ratingAttr);
        matchesRating = !isNaN(bookRating) && bookRating === parseFloat(currentRating);
      }

      const matchesReview = !filterReview || hasReview;

      book.style.display = (matchesSearch && matchesRating && matchesReview) ? '' : 'none';
    });

    updateCount();
  } 

  searchInput.addEventListener('input', filterBooks);

  searchInput.addEventListener('focus', () => {
    searchHint.style.display = 'none';
    searchInput.setAttribute('placeholder', '');
  });

  searchInput.addEventListener('blur', () => {
    if (!searchInput.value) {
      searchHint.style.display = '';
      searchInput.setAttribute('placeholder', 'Search...');
    }
  });

  window.addEventListener('dropdown-select', (e) => {
    currentRating = ratingMap[e.detail.option] ?? 'all';
    filterBooks();
  });

  reviewFilterBtn?.addEventListener('click', () => {
    filterReview = !filterReview;
    reviewFilterBtn.setAttribute('aria-pressed', String(filterReview));
    reviewFilterBtn.classList.toggle('active', filterReview);
    filterBooks();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/') {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // Set initial count
  updateCount();
</script>