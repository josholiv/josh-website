        </svg>
        <p class="raincloud-hint">Scroll to zoom · drag to pan · double-click to reset</p>
      </div>
    </div>
  )}

  {pubYears.length >= 4 && (
    <div class="stats-charts">
      <div class="chart-section chart-section-wide">
        <p class="chart-title">Publication / Composition Date Distribution</p>
        <svg viewBox={`0 0 ${RC_SVG_W} ${RC_SVG_H}`} preserveAspectRatio="none" class="raincloud-svg" role="img" aria-label="Raincloud plot of book publication dates" data-rc-info={pyJsData}>
