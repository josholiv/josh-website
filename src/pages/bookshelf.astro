<script>
  const searchInput = document.getElementById('bookSearch');
  const searchHint = document.querySelector('.search-hint');
  const bookCount = document.getElementById('bookCount');
  const books = Array.from(document.querySelectorAll('.book-card'));
  const reviewFilterBtn = document.getElementById('reviewFilterBtn');
  let currentRating = 'all';
  let filterReview = false;

  const ratingMap = {
    '★ — ★★★★★': 'all',
    '★★★★★': '5',
    '★★★★': '4',
    '★★★': '3',
    '★★': '2',
    '★': '1',
    'Not rated': 'unrated',
  };

  function updateCount() {
    const visible = books.filter(b => b.style.display !== 'none').length;
    bookCount.textContent = `${visible} of ${books.length}`;
  }

  function filterBooks() {
    const query = searchInput.value.toLowerCase();

    books.forEach(book => {
      const title = book.querySelector('.book-title')?.textContent.toLowerCase() || '';
      const author = book.querySelector('.book-author')?.textContent.toLowerCase() || '';
      const year = book.querySelector('.book-year')?.textContent || '';
      const ratingAttr = book.dataset.rating;
      const hasReview = book.dataset.hasReview === 'true';

      const matchesSearch = title.includes(query) || author.includes(query) || year.includes(query);

      let matchesRating = true;
      if (currentRating === 'unrated') {
        matchesRating = ratingAttr === 'none';
      } else if (currentRating !== 'all') {
        const bookRating = parseFloat(ratingAttr);
        matchesRating = !isNaN(bookRating) && bookRating === parseFloat(currentRating);
      }

      const matchesReview = !filterReview || hasReview;

      book.style.display = (matchesSearch && matchesRating && matchesReview) ? '' : 'none';
    });

    updateCount();
  } 

  searchInput.addEventListener('input', filterBooks);

  searchInput.addEventListener('focus', () => {
    searchHint.style.display = 'none';
    searchInput.setAttribute('placeholder', '');
  });

  searchInput.addEventListener('blur', () => {
    if (!searchInput.value) {
      searchHint.style.display = '';
      searchInput.setAttribute('placeholder', 'Search...');
    }
  });

  window.addEventListener('dropdown-select', (e) => {
    currentRating = ratingMap[e.detail.option] ?? 'all';
    filterBooks();
  });

  reviewFilterBtn?.addEventListener('click', () => {
    filterReview = !filterReview;
    reviewFilterBtn.setAttribute('aria-pressed', String(filterReview));
    reviewFilterBtn.classList.toggle('active', filterReview);
    filterBooks();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/') {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // Set initial count
  updateCount();

  // Raincloud SVG: data-driven zoom/pan — repositions elements without scaling the SVG.
  (function () {
    const SVG_W = 600;

    interface RcInfo {
      xLoFull: number; xHiFull: number;
      q1: number; median: number; q3: number;
      whiskerLo: number; whiskerHi: number;
      densitySamples: { val: number; d: number }[];
      maxD: number;
      dots: { val: number; cy: number; outlier: boolean; title: string }[];
      ticks: { val: number; label: string }[];
      PAD_L: number; PLOT_W: number;
      CLOUD_BASE_Y: number; CLOUD_H: number;
      BOX_Y: number; BOX_H: number; AXIS_Y: number;
      axisLabel: string;
      capYear?: number;
      defaultXLo?: number;
      defaultXHi?: number;
    }

    function niceStep(rawStep: number): number {
      if (rawStep <= 0) return 1;
      const mag = Math.pow(10, Math.floor(Math.log10(rawStep)));
      for (const n of [1, 2, 2.5, 5, 10]) {
        if (mag * n >= rawStep) return mag * n;
      }
      return mag * 10;
    }

    function fmtTickVal(val: number, axisLabel: string): string {
      if (axisLabel === 'year') {
        const r = Math.round(val);
        return r < 0 ? String(Math.abs(r)) + ' BCE' : String(r) + ' CE';
      }
      const r = Math.round(val);
      if (Math.abs(r) >= 1000) return (r / 1000).toFixed(r % 1000 === 0 ? 0 : 1) + 'k';
      return String(r);
    }

    function computeDynamicTicks(xLo: number, xHi: number, axisLabel: string, targetCount: number, capYear?: number): { val: number; label: string }[] {
      let step = niceStep((xHi - xLo) / targetCount);
      if (axisLabel === 'year' && step > 500) step = 500; // cap year-axis ticks at 500-year increments
      const start = Math.ceil(xLo / step) * step;
      const ticks: { val: number; label: string }[] = [];
      for (let t = start; t <= xHi + step * 0.001; t += step) {
        if (capYear !== undefined && Math.round(t) > capYear) break;
        ticks.push({ val: t, label: fmtTickVal(t, axisLabel) });
      }
      return ticks;
    }

    function getInfo(svg: Element): RcInfo | null {
      try { return JSON.parse((svg as HTMLElement).dataset.rcInfo || ''); }
      catch { return null; }
    }

    // Recompute and repaint all SVG elements for the given data x-range.
    function applyRange(svg: Element, xLo: number, xHi: number) {
      const info = getInfo(svg);
      if (!info) return;
      const { PAD_L, CLOUD_BASE_Y, CLOUD_H, maxD, AXIS_Y } = info;
      // Lock viewBox to the rendered pixel size so violins/box/dots keep
      // their physical dimensions regardless of viewport width.
      const rect = svg.getBoundingClientRect();
      const rw = rect.width || SVG_W;
      const rh = rect.height || 260;
      const PAD_R = SVG_W - PAD_L - info.PLOT_W; // original right padding
      const PLOT_W = Math.max(rw - PAD_L - PAD_R, 1);
      svg.setAttribute('viewBox', `0 0 ${rw} ${rh}`);
      // Resize the axis line + clip-path to the new plot width
      const axisLn = svg.querySelector('.rc-axis');
      if (axisLn) axisLn.setAttribute('x2', String(PAD_L + PLOT_W));
      const clipRect = svg.querySelector('defs clipPath rect');
      if (clipRect) clipRect.setAttribute('width', String(PLOT_W));
      const xs = (v: number) => PAD_L + ((v - xLo) / (xHi - xLo)) * PLOT_W;

      // Density cloud path
      const cloud = svg.querySelector('.rc-cloud');
      if (cloud && info.densitySamples.length) {
        const toY = (d: number) => CLOUD_BASE_Y - (d / maxD) * CLOUD_H;
        const s = info.densitySamples;
        const parts = ['M ' + xs(s[0].val).toFixed(1) + ',' + CLOUD_BASE_Y];
        for (const { val, d } of s) parts.push('L ' + xs(val).toFixed(1) + ',' + toY(d).toFixed(1));
        parts.push('L ' + xs(s[s.length - 1].val).toFixed(1) + ',' + CLOUD_BASE_Y + ' Z');
        cloud.setAttribute('d', parts.join(' '));
      }

      // Box and whiskers
      const q1x = xs(info.q1), q3x = xs(info.q3);
      const medX = xs(info.median);
      const wLoX = xs(info.whiskerLo), wHiX = xs(info.whiskerHi);

      const ws = svg.querySelectorAll('.rc-whisker');
      if (ws.length >= 4) {
        ws[0].setAttribute('x1', wLoX.toFixed(1)); ws[0].setAttribute('x2', q1x.toFixed(1));
        ws[1].setAttribute('x1', q3x.toFixed(1));  ws[1].setAttribute('x2', wHiX.toFixed(1));
        ws[2].setAttribute('x1', wLoX.toFixed(1)); ws[2].setAttribute('x2', wLoX.toFixed(1));
        ws[3].setAttribute('x1', wHiX.toFixed(1)); ws[3].setAttribute('x2', wHiX.toFixed(1));
      }
      const box = svg.querySelector('.rc-box');
      if (box) {
        box.setAttribute('x', q1x.toFixed(1));
        box.setAttribute('width', Math.max(q3x - q1x, 2).toFixed(1));
      }
      const med = svg.querySelector('.rc-median');
      if (med) { med.setAttribute('x1', medX.toFixed(1)); med.setAttribute('x2', medX.toFixed(1)); }
      const bwHit = svg.querySelector('.rc-bw-hit');
      if (bwHit) {
        bwHit.setAttribute('x', wLoX.toFixed(1));
        bwHit.setAttribute('width', Math.max(wHiX - wLoX, 4).toFixed(1));
      }

      // Dots
      svg.querySelectorAll('.rc-dot').forEach((dot: Element, i: number) => {
        if (info.dots[i] !== undefined) dot.setAttribute('cx', xs(info.dots[i].val).toFixed(1));
      });

      // Rebuild ticks at the granularity appropriate for the current zoom range
      const renderedWidth = svg.getBoundingClientRect().width;
      const targetCount = renderedWidth < 400 ? 4 : 6;
      const dynamicTicks = computeDynamicTicks(xLo, xHi, info.axisLabel, targetCount, info.capYear);
      const container = svg.querySelector('.rc-ticks-container');
      if (container) {
        while (container.firstChild) container.removeChild(container.firstChild);
        const NS = 'http://www.w3.org/2000/svg';
        for (const { val, label } of dynamicTicks) {
          const tx = xs(val);
          if (tx < PAD_L - 1 || tx > PAD_L + PLOT_W + 1) continue;
          const txStr = tx.toFixed(1);
          const g = document.createElementNS(NS, 'g');
          const ln = document.createElementNS(NS, 'line');
          ln.setAttribute('x1', txStr); ln.setAttribute('x2', txStr);
          ln.setAttribute('y1', String(AXIS_Y)); ln.setAttribute('y2', String(AXIS_Y + 4));
          ln.setAttribute('class', 'rc-tick');
          const txt = document.createElementNS(NS, 'text');
          txt.setAttribute('x', txStr);
          txt.setAttribute('y', String(AXIS_Y + 18));
          txt.setAttribute('class', 'rc-tick-label');
          txt.setAttribute('text-anchor', 'middle');
          txt.textContent = label;
          g.appendChild(ln);
          g.appendChild(txt);
          container.appendChild(g);
        }
      }

      // Axis label: keep centered over the visible plot area
      const axLabel = svg.querySelector('.rc-axis-label');
      if (axLabel) axLabel.setAttribute('x', (PAD_L + PLOT_W / 2).toFixed(1));

      // Re-apply text sizing to newly created tick labels
      updateText(svg);
    }

    // Maintain 0.875rem physical text size and correct y-offsets below axis.
    function updateText(svg: Element) {
      // viewBox is now 1:1 with CSS pixels, so text sizes and offsets are physical.
      const rootFs = parseFloat(getComputedStyle(document.documentElement).fontSize);
      const fs = rootFs * 0.875;
      const AXIS_Y = 209;
      // Inline styles ensure dynamically created elements (no Astro scope attr) match
      svg.querySelectorAll('.rc-tick-label').forEach((el: Element) => {
        const st = (el as SVGElement).style;
        st.fontSize = fs + 'px';
        st.setProperty('fill', 'var(--text-faint)');
        st.fontFamily = '"Atkinson Hyperlegible Mono", monospace';
        (el as SVGTextElement).setAttribute('y', String(AXIS_Y + 18));
      });
      svg.querySelectorAll('.rc-axis-label').forEach((el: Element) => {
        const st = (el as SVGElement).style;
        st.fontSize = fs + 'px';
        st.setProperty('fill', 'var(--text-muted)');
        st.fontFamily = '"Atkinson Hyperlegible Mono", monospace';
        st.fontWeight = '700';
        (el as SVGTextElement).setAttribute('y', String(AXIS_Y + 44));
      });
    }

    function updateZoomIndicator(svg: Element, info: RcInfo, xLo: number, xHi: number) {
      const hint = svg.nextElementSibling as HTMLElement | null;
      if (!hint || !hint.classList.contains('raincloud-hint')) return;
      const atFull = Math.abs(xLo - info.xLoFull) < 0.01 && Math.abs(xHi - info.xHiFull) < 0.01;
      if (atFull) {
        hint.textContent = 'Scroll to zoom · drag to pan · double-click to reset';
        hint.classList.remove('rc-hint-zoomed');
        return;
      }
      const fmt = (v: number) => {
        if (info.axisLabel === 'year') {
          const r = Math.round(v);
          return r < 0 ? String(Math.abs(r)) + ' BCE' : String(r) + ' CE';
        }
        if (Math.abs(v) >= 1000) return (v / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
        return String(Math.round(v));
      };
      hint.textContent = 'Zoomed to ' + fmt(xLo) + ' – ' + fmt(xHi) + (info.axisLabel === 'year' ? '' : ' ' + info.axisLabel) + ' · double-click to reset';
      hint.classList.add('rc-hint-zoomed');
    }

    function updateRaincloud(svg: Element) {
      updateText(svg);
      const info = getInfo(svg);
      if (!info) return;
      const xLo = parseFloat((svg as HTMLElement).dataset.xLo ?? 'NaN');
      const xHi = parseFloat((svg as HTMLElement).dataset.xHi ?? 'NaN');
      applyRange(svg, isNaN(xLo) ? info.xLoFull : xLo, isNaN(xHi) ? info.xHiFull : xHi);
    }

    function setupZoom(svg: Element) {
      const info = getInfo(svg);
      if (!info) return;
      const el = svg as HTMLElement;

      let xLo = info.defaultXLo !== undefined ? Math.max(info.xLoFull, info.defaultXLo) : info.xLoFull;
      let xHi = info.defaultXHi !== undefined ? Math.min(info.xHiFull, info.defaultXHi) : info.xHiFull;
      el.dataset.xLo = String(xLo);
      el.dataset.xHi = String(xHi);
      applyRange(svg, xLo, xHi);
      updateZoomIndicator(svg, info, xLo, xHi);

      const PAD_R = SVG_W - info.PAD_L - info.PLOT_W;
      const plotPxOf = (rect: DOMRect) => Math.max(rect.width - info.PAD_L - PAD_R, 1);

      svg.addEventListener('wheel', (ev: Event) => {
        const e = ev as WheelEvent;
        e.preventDefault();
        const rect = svg.getBoundingClientRect();
        const plotLeft = info.PAD_L;
        const plotPx   = plotPxOf(rect);
        const mouseRatio = Math.max(0, Math.min(1, (e.clientX - rect.left - plotLeft) / plotPx));
        const pivot = xLo + mouseRatio * (xHi - xLo);
        const factor = e.deltaY > 0 ? 1.25 : 0.8;
        const minSpan = (info.xHiFull - info.xLoFull) / 50;
        const newSpan = Math.max(minSpan, Math.min(info.xHiFull - info.xLoFull, (xHi - xLo) * factor));
        xLo = Math.max(info.xLoFull, Math.min(info.xHiFull - newSpan, pivot - mouseRatio * newSpan));
        xHi = xLo + newSpan;
        el.dataset.xLo = String(xLo);
        el.dataset.xHi = String(xHi);
        applyRange(svg, xLo, xHi);
        updateZoomIndicator(svg, info, xLo, xHi);
      }, { passive: false } as AddEventListenerOptions);

      let dragging = false;
      let dragStartX = 0, dragStartLo = 0, dragStartHi = 0;

      svg.addEventListener('mousedown', (ev: Event) => {
        const e = ev as MouseEvent;
        dragging = true;
        dragStartX = e.clientX;
        dragStartLo = xLo; dragStartHi = xHi;
        el.style.cursor = 'grabbing';
      });
      window.addEventListener('mousemove', (ev: Event) => {
        if (!dragging) return;
        const e = ev as MouseEvent;
        const rect = svg.getBoundingClientRect();
        const plotPx = plotPxOf(rect);
        const dxData = -((e.clientX - dragStartX) / plotPx) * (dragStartHi - dragStartLo);
        const span = dragStartHi - dragStartLo;
        xLo = Math.max(info.xLoFull, Math.min(info.xHiFull - span, dragStartLo + dxData));
        xHi = xLo + span;
        el.dataset.xLo = String(xLo);
        el.dataset.xHi = String(xHi);
        applyRange(svg, xLo, xHi);
        updateZoomIndicator(svg, info, xLo, xHi);
      });
      window.addEventListener('mouseup', () => {
        if (!dragging) return;
        dragging = false;
        el.style.cursor = 'grab';
      });

      svg.addEventListener('dblclick', () => {
        xLo = info.xLoFull; xHi = info.xHiFull;
        el.dataset.xLo = String(xLo); el.dataset.xHi = String(xHi);
        applyRange(svg, xLo, xHi);
        updateZoomIndicator(svg, info, xLo, xHi);
      });

      // Touch: single-finger pan, two-finger pinch-to-zoom, double-tap to reset
      let lastTouchDist = 0;
      let lastTap = 0;

      svg.addEventListener('touchstart', (ev: Event) => {
        const e = ev as TouchEvent;
        e.preventDefault();
        if (e.touches.length === 1) {
          dragging = true;
          dragStartX = e.touches[0].clientX;
          dragStartLo = xLo; dragStartHi = xHi;
        } else if (e.touches.length === 2) {
          dragging = false;
          lastTouchDist = Math.hypot(
            e.touches[1].clientX - e.touches[0].clientX,
            e.touches[1].clientY - e.touches[0].clientY,
          );
        }
      }, { passive: false } as AddEventListenerOptions);

      svg.addEventListener('touchmove', (ev: Event) => {
        const e = ev as TouchEvent;
        e.preventDefault();
        if (e.touches.length === 1 && dragging) {
          const rect = svg.getBoundingClientRect();
          const plotPx = plotPxOf(rect);
          const dxData = -((e.touches[0].clientX - dragStartX) / plotPx) * (dragStartHi - dragStartLo);
          const span = dragStartHi - dragStartLo;
          xLo = Math.max(info.xLoFull, Math.min(info.xHiFull - span, dragStartLo + dxData));
          xHi = xLo + span;
          el.dataset.xLo = String(xLo); el.dataset.xHi = String(xHi);
          applyRange(svg, xLo, xHi);
          updateZoomIndicator(svg, info, xLo, xHi);
        } else if (e.touches.length === 2 && lastTouchDist > 0) {
          const dist = Math.hypot(
            e.touches[1].clientX - e.touches[0].clientX,
            e.touches[1].clientY - e.touches[0].clientY,
          );
          const scale = lastTouchDist / dist;
          lastTouchDist = dist;
          const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
          const rect = svg.getBoundingClientRect();
          const plotLeft = info.PAD_L;
          const plotPx = plotPxOf(rect);
          const mouseRatio = Math.max(0, Math.min(1, (midX - rect.left - plotLeft) / plotPx));
          const pivot = xLo + mouseRatio * (xHi - xLo);
          const minSpan = (info.xHiFull - info.xLoFull) / 50;
          const newSpan = Math.max(minSpan, Math.min(info.xHiFull - info.xLoFull, (xHi - xLo) * scale));
          xLo = Math.max(info.xLoFull, Math.min(info.xHiFull - newSpan, pivot - mouseRatio * newSpan));
          xHi = xLo + newSpan;
          el.dataset.xLo = String(xLo); el.dataset.xHi = String(xHi);
          applyRange(svg, xLo, xHi);
          updateZoomIndicator(svg, info, xLo, xHi);
        }
      }, { passive: false } as AddEventListenerOptions);

      svg.addEventListener('touchend', (ev: Event) => {
        const e = ev as TouchEvent;
        if (e.touches.length === 0) {
          dragging = false;
          lastTouchDist = 0;
          const now = Date.now();
          if (now - lastTap < 300) {
            xLo = info.xLoFull; xHi = info.xHiFull;
            el.dataset.xLo = String(xLo); el.dataset.xHi = String(xHi);
            applyRange(svg, xLo, xHi);
            updateZoomIndicator(svg, info, xLo, xHi);
          }
          lastTap = now;
        }
      });

      el.style.cursor = 'grab';
      el.style.touchAction = 'none';
    }

    // Tooltip for individual data points
    const rcTooltip = document.createElement('div');
    rcTooltip.id = 'rc-tooltip';
    document.body.appendChild(rcTooltip);

    function attachDotTooltips(svg: Element) {
      const info = getInfo(svg);
      if (!info) return;
      let tapTimer: ReturnType<typeof setTimeout> | null = null;

      const positionTooltip = (cx: number, cy: number) => {
        const vw = window.innerWidth;
        const tx = (cx + 14 + 220 > vw) ? cx - 234 : cx + 14;
        rcTooltip.style.left = Math.max(8, tx) + 'px';
        rcTooltip.style.top = Math.max(10, cy - 44) + 'px';
      };

      svg.querySelectorAll('.rc-dot').forEach((dot: Element, i: number) => {
        const entry = info.dots[i];
        if (!entry?.title) return;

        // Desktop: hover
        dot.addEventListener('mouseenter', (ev: Event) => {
          const e = ev as MouseEvent;
          rcTooltip.textContent = entry.title;
          positionTooltip(e.clientX, e.clientY);
          rcTooltip.style.display = 'block';
        });
        dot.addEventListener('mousemove', (ev: Event) => {
          const e = ev as MouseEvent;
          positionTooltip(e.clientX, e.clientY);
        });
        dot.addEventListener('mouseleave', () => {
          rcTooltip.style.display = 'none';
        });

        // Mobile: tap (detect by small movement threshold)
        let tapStartX = 0, tapStartY = 0;
        dot.addEventListener('touchstart', (ev: Event) => {
          const t = (ev as TouchEvent).touches[0];
          tapStartX = t.clientX; tapStartY = t.clientY;
        }, { passive: true } as AddEventListenerOptions);

        dot.addEventListener('touchend', (ev: Event) => {
          const t = (ev as TouchEvent).changedTouches[0];
          const moved = Math.hypot(t.clientX - tapStartX, t.clientY - tapStartY);
          if (moved < 10) {
            if (tapTimer) clearTimeout(tapTimer);
            rcTooltip.textContent = entry.title;
            positionTooltip(t.clientX, t.clientY);
            rcTooltip.style.display = 'block';
            tapTimer = setTimeout(() => {
              rcTooltip.style.display = 'none';
              tapTimer = null;
            }, 3000);
          }
        }, { passive: true } as AddEventListenerOptions);
      });
    }

    function attachBoxTooltips(svg: Element) {
      const info = getInfo(svg);
      if (!info) return;
      const hit = svg.querySelector('.rc-bw-hit');
      if (!hit) return;

      const fmt = (v: number) => fmtTickVal(v, info.axisLabel);
      const fmtRange = (v: number) => {
        const r = Math.round(v);
        if (Math.abs(r) >= 1000) return (r / 1000).toFixed(r % 1000 === 0 ? 0 : 1) + 'k';
        return String(r);
      };
      const html =
        '<div><strong>Median:</strong> ' + fmt(info.median) + '</div>' +
        '<div><strong>Q1:</strong> ' + fmt(info.q1) + '</div>' +
        '<div><strong>Q3:</strong> ' + fmt(info.q3) + '</div>' +
        '<div><strong>IQR:</strong> ' + fmtRange(info.q3 - info.q1) + '</div>' +
        '<div><strong>Whiskers:</strong> ' + fmt(info.whiskerLo) + ' – ' + fmt(info.whiskerHi) + '</div>';

      const positionTooltip = (cx: number, cy: number) => {
        const vw = window.innerWidth;
        const tx = (cx + 14 + 220 > vw) ? cx - 234 : cx + 14;
        rcTooltip.style.left = Math.max(8, tx) + 'px';
        rcTooltip.style.top = Math.max(10, cy - 70) + 'px';
      };

      hit.addEventListener('mouseenter', (ev: Event) => {
        const e = ev as MouseEvent;
        rcTooltip.innerHTML = html;
        positionTooltip(e.clientX, e.clientY);
        rcTooltip.style.display = 'block';
      });
      hit.addEventListener('mousemove', (ev: Event) => {
        const e = ev as MouseEvent;
        positionTooltip(e.clientX, e.clientY);
      });
      hit.addEventListener('mouseleave', () => {
        rcTooltip.style.display = 'none';
      });

      let tapStartX = 0, tapStartY = 0;
      let tapTimer: ReturnType<typeof setTimeout> | null = null;
      hit.addEventListener('touchstart', (ev: Event) => {
        const t = (ev as TouchEvent).touches[0];
        tapStartX = t.clientX; tapStartY = t.clientY;
      }, { passive: true } as AddEventListenerOptions);
      hit.addEventListener('touchend', (ev: Event) => {
        const t = (ev as TouchEvent).changedTouches[0];
        const moved = Math.hypot(t.clientX - tapStartX, t.clientY - tapStartY);
        if (moved < 10) {
          if (tapTimer) clearTimeout(tapTimer);
          rcTooltip.innerHTML = html;
          positionTooltip(t.clientX, t.clientY);
          rcTooltip.style.display = 'block';
          tapTimer = setTimeout(() => {
            rcTooltip.style.display = 'none';
            tapTimer = null;
          }, 4000);
        }
      }, { passive: true } as AddEventListenerOptions);
    }

    const rainSvgs = document.querySelectorAll('.raincloud-svg');
    rainSvgs.forEach((svg: Element) => { updateRaincloud(svg); setupZoom(svg); attachDotTooltips(svg); attachBoxTooltips(svg); });

    if (window.ResizeObserver) {
      const ro = new ResizeObserver((entries: ResizeObserverEntry[]) => {
        entries.forEach((e: ResizeObserverEntry) => updateRaincloud(e.target));
      });
      rainSvgs.forEach((svg: Element) => ro.observe(svg));
    }
  })();

  // Stat card + chart card mouse glow
  document.querySelectorAll('.stat-card, .chart-section').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });

  // World map: tooltip (hover + tap) + zoom/pan
  (() => {
    const wrapper = document.querySelector('.world-map') as HTMLElement | null;
    if (!wrapper) return;
    const svg = wrapper.querySelector('svg') as SVGSVGElement | null;
    if (!svg) return;

    // ── Tooltip (shares #rc-tooltip with the raincloud plots) ──
    let tip = document.getElementById('rc-tooltip') as HTMLDivElement | null;
    if (!tip) {
      tip = document.createElement('div');
      tip.id = 'rc-tooltip';
      document.body.appendChild(tip);
    }
    const hideTip = () => { tip!.style.display = 'none'; };
    const showTip = (p: SVGPathElement, clientX: number, clientY: number) => {
      const iso = p.getAttribute('data-iso') || p.id || '';
      const count = Number(p.getAttribute('data-count') || '0');
      const name = p.getAttribute('aria-label') || iso.toUpperCase();
      tip!.innerHTML = `<strong>${name}:</strong> ${count} ${count === 1 ? 'author' : 'authors'}`;
      tip!.style.display = 'block';
      const vw = window.innerWidth;
      const tx = (clientX + 14 + 220 > vw) ? clientX - 234 : clientX + 14;
      tip!.style.left = Math.max(8, tx) + 'px';
      tip!.style.top = Math.max(10, clientY - 44) + 'px';
    };

    // ── Zoom / pan state ────────────────────────────────
    const ORIG = { x: 0, y: 0, w: 1010, h: 666 };
    let view = { ...ORIG };
    const MIN_W = ORIG.w / 12;
    const mapHint = wrapper.parentElement?.querySelector('.world-map-hint') as HTMLElement | null;
    const updateMapHint = () => {
      if (!mapHint) return;
      const isZoomed = view.w < ORIG.w - 0.01;
      if (isZoomed) {
        mapHint.textContent = 'Zoomed · drag to pan · double-click to reset';
        mapHint.classList.add('rc-hint-zoomed');
      } else {
        mapHint.textContent = 'Scroll to zoom · drag to pan · double-click to reset';
        mapHint.classList.remove('rc-hint-zoomed');
      }
    };
    const applyView = () => { svg.setAttribute('viewBox', `${view.x} ${view.y} ${view.w} ${view.h}`); updateMapHint(); };
    const clamp = () => {
      if (view.w > ORIG.w) view.w = ORIG.w;
      if (view.w < MIN_W) view.w = MIN_W;
      view.h = view.w * (ORIG.h / ORIG.w);
      view.x = Math.max(ORIG.x, Math.min(ORIG.x + ORIG.w - view.w, view.x));
      view.y = Math.max(ORIG.y, Math.min(ORIG.y + ORIG.h - view.h, view.y));
    };
    const zoomAt = (clientX: number, clientY: number, factor: number) => {
      const r = svg.getBoundingClientRect();
      const sx = (clientX - r.left) / r.width;
      const sy = (clientY - r.top) / r.height;
      const beforeX = view.x + sx * view.w;
      const beforeY = view.y + sy * view.h;
      view.w /= factor;
      clamp();
      view.x = beforeX - sx * view.w;
      view.y = beforeY - sy * view.h;
      clamp();
      applyView();
    };
    const reset = () => { view = { ...ORIG }; applyView(); hideTip(); };

    svg.addEventListener('wheel', (e: WheelEvent) => {
      e.preventDefault();
      const factor = e.deltaY < 0 ? 1.2 : 1 / 1.2;
      zoomAt(e.clientX, e.clientY, factor);
    }, { passive: false });

    svg.addEventListener('dblclick', (e) => { e.preventDefault(); reset(); });

    // ── Pointer-based pan + pinch + tap ─────────────────
    type P = { x: number; y: number };
    const active = new Map<number, P>();
    let dragStart: { x: number; y: number; vx: number; vy: number } | null = null;
    let pinchStart: { dist: number; view: typeof view } | null = null;
    let movedDuringPress = false;
    let pressStart = 0;
    const MOVE_THRESHOLD_PX = 6;

    // Listeners attach to window on the first pointerdown so we keep getting
    // move/up events even when a finger leaves the SVG bounds — and we avoid
    // setPointerCapture, which is unreliable for multi-touch on mobile Safari.
    const onPointerMove = (e: PointerEvent) => {
      const p = active.get(e.pointerId);
      if (!p) return;
      p.x = e.clientX; p.y = e.clientY;
      if (active.size === 1 && dragStart) {
        const dx = e.clientX - dragStart.x;
        const dy = e.clientY - dragStart.y;
        if (Math.abs(dx) + Math.abs(dy) > MOVE_THRESHOLD_PX) movedDuringPress = true;
        const r = svg.getBoundingClientRect();
        view.x = dragStart.vx - (dx / r.width) * view.w;
        view.y = dragStart.vy - (dy / r.height) * view.h;
        clamp();
        applyView();
        if (movedDuringPress) hideTip();
      } else if (active.size === 2 && pinchStart) {
        const pts = Array.from(active.values());
        const dist = Math.hypot(pts[1].x - pts[0].x, pts[1].y - pts[0].y);
        if (pinchStart.dist > 0) {
          const cx = (pts[0].x + pts[1].x) / 2;
          const cy = (pts[0].y + pts[1].y) / 2;
          view = { ...pinchStart.view };
          applyView();
          zoomAt(cx, cy, dist / pinchStart.dist);
        }
        movedDuringPress = true;
        hideTip();
      }
    };

    const onPointerEnd = (e: PointerEvent) => {
      if (!active.has(e.pointerId)) return;
      const endX = e.clientX, endY = e.clientY;
      active.delete(e.pointerId);
      if (active.size === 0) {
        svg.classList.remove('is-panning');
        const wasTap = dragStart && !movedDuringPress && (performance.now() - pressStart) < 500;
        dragStart = null;
        pinchStart = null;
        movedDuringPress = false;
        window.removeEventListener('pointermove', onPointerMove);
        window.removeEventListener('pointerup', onPointerEnd);
        window.removeEventListener('pointercancel', onPointerEnd);
        if (wasTap) {
          const el = document.elementFromPoint(endX, endY);
          if (el && el.tagName.toLowerCase() === 'path' && wrapper.contains(el)) {
            showTip(el as SVGPathElement, endX, endY);
          } else {
            hideTip();
          }
        }
      } else if (active.size === 1) {
        // Going from pinch back to single finger: reseed pan state from the
        // surviving pointer so the map stays interactive instead of locking up.
        const [survivor] = Array.from(active.values());
        dragStart = { x: survivor.x, y: survivor.y, vx: view.x, vy: view.y };
        pinchStart = null;
        movedDuringPress = true;
      }
    };

    svg.addEventListener('pointerdown', (e: PointerEvent) => {
      active.set(e.pointerId, { x: e.clientX, y: e.clientY });
      if (active.size === 1) {
        dragStart = { x: e.clientX, y: e.clientY, vx: view.x, vy: view.y };
        pinchStart = null;
        movedDuringPress = false;
        pressStart = performance.now();
        svg.classList.add('is-panning');
        window.addEventListener('pointermove', onPointerMove, { passive: true });
        window.addEventListener('pointerup', onPointerEnd);
        window.addEventListener('pointercancel', onPointerEnd);
      } else if (active.size === 2) {
        const pts = Array.from(active.values());
        pinchStart = {
          dist: Math.hypot(pts[1].x - pts[0].x, pts[1].y - pts[0].y),
          view: { ...view },
        };
        dragStart = null;
      }
    });

    // ── Desktop hover (mouse only — skipped if mid-drag) ─
    const paths = wrapper.querySelectorAll<SVGPathElement>('path');
    paths.forEach((p) => {
      p.addEventListener('mousemove', (e: MouseEvent) => {
        if (movedDuringPress || active.size > 0) return;
        showTip(p, e.clientX, e.clientY);
      });
      p.addEventListener('mouseleave', () => {
        if (active.size === 0) hideTip();
      });
    });

    // Dismiss tooltip on outside interaction
    document.addEventListener('pointerdown', (e) => {
      if (!wrapper.contains(e.target as Node)) hideTip();
    });
  })();
</script>