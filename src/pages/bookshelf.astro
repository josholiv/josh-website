            <line x1={pyWhiskerHiX} y1={RC_BOX_Y + 3} x2={pyWhiskerHiX} y2={RC_BOX_Y + RC_BOX_H - 3} class="rc-whisker" />
            <rect x={pyBoxX1} y={RC_BOX_Y} width={Math.max(pyBoxX2 - pyBoxX1, 2)} height={RC_BOX_H} class="rc-box" />
            <line x1={pyMedianX} y1={RC_BOX_Y} x2={pyMedianX} y2={RC_BOX_Y + RC_BOX_H} class="rc-median" />
