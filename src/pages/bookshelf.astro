        </svg>
        <p class="raincloud-hint">Scroll to zoom · drag to pan · double-click to reset</p>
      </div>
    </div>
  )}

  <div class="stats-charts">
    <div class="chart-section chart-section-wide">
      <p class="chart-title">Authors by country</p>
      <div class="world-map" set:html={worldMapSvg}></div>
      {totalCountries > 0 ? (
        <>
          <p class="world-map-summary">{totalMappedAuthors} {totalMappedAuthors === 1 ? 'author' : 'authors'} across {totalCountries} {totalCountries === 1 ? 'country' : 'countries'}</p>
          <p class="raincloud-hint world-map-hint">Scroll to zoom · drag to pan · double-click to reset</p>
        </>
      ) : (
        <p class="raincloud-hint">No country data yet — add author → ISO mappings in src/data/book-countries.json</p>
      )}
    </div>
  </div>

</BaseLayout>

