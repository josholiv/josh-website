---
import { getCollection } from "astro:content";
import { Info } from "lucide-preact";

import BaseLayout from "../layouts/BaseLayout.astro";
import BlogSorter from "../components/BlogSorter.jsx"; 
import Callout from '../components/Callout.astro';

const pageTitle = "Josh Olivier - Blog";
const allPosts = await getCollection("blog");
---

<BaseLayout pageTitle={pageTitle} shouldCenterTitle={false} shouldShowTitle={false}>

   <h1>Blog</h1>

   <div class="wave-container">
    <div class="wave wave-small"></div>
    <div class="wave wave-big"></div>
  </div>

  <Callout type="tip">
   Use <code>Show Tags</code> to filter posts by tag. Use the <code>Newest</code> / <code>Oldest</code> dropdown to sort posts chronologically.
  </Callout>

   <div style={{ marginTop: '2rem'}}>
      <BlogSorter posts={allPosts} client:load /> 
   </div>
   
</BaseLayout>
