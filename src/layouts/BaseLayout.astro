---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource/dm-serif-text/latin-400.css';
import '@fontsource/dm-serif-text/latin-400-italic.css';
import '@fontsource/ubuntu-mono/latin-400.css';
import '@fontsource/ubuntu-mono/latin-700.css';
import '@fontsource/ubuntu-mono/latin-400-italic.css';
import '@fontsource/ubuntu-mono/latin-700-italic.css';
import '../styles/font-display-override.css';

// Preload critical font files so they're fetched before CSS is parsed,
// eliminating FOUT (flash of unstyled text) on every page load.
import interFont from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import dmSerifFont from '@fontsource/dm-serif-text/files/dm-serif-text-latin-400-normal.woff2?url';
import ubuntuMonoFont from '@fontsource/ubuntu-mono/files/ubuntu-mono-latin-400-normal.woff2?url';

const { pageTitle, titleHtml, shouldCenterTitle, shouldShowTitle = true, showBanner = true, footerImageLoading = 'lazy', description, descriptionHtml, ogImage, ogType = 'website' } = Astro.props;

const siteUrl = 'https://josholivier.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageAbsolute = ogImage ? new URL(ogImage, siteUrl).toString() : undefined;
---

<html lang="en">
  <head>
    <script is:inline>
      const stored = localStorage?.getItem("theme");
      if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
        document.documentElement.dataset.theme = "dark";
      } else {
        document.documentElement.classList.remove("dark");
        document.documentElement.dataset.theme = "light";
      }
      document.documentElement.classList.add("theme-loading");
    </script>
  
    <meta charset="utf-8" />

    <link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={dmSerifFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={ubuntuMonoFont} as="font" type="font/woff2" crossorigin />
    
    <link rel="icon" type="image/svg+xml" href="/josh-favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    {description && <meta name="description" content={description} />}

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    {ogImageAbsolute && <meta property="og:image" content={ogImageAbsolute} />}
    {ogImageAbsolute && <meta property="og:image:width" content="1200" />}
    {ogImageAbsolute && <meta property="og:image:height" content="630" />}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content={ogImageAbsolute ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageAbsolute && <meta name="twitter:image" content={ogImageAbsolute} />}
  </head>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LZBBDCSVZC"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LZBBDCSVZC');
  </script> 

  <body>
    <div class="page-wrapper">
      <Header />
      <main class="main-content">
        {shouldShowTitle && showBanner && (
          <div class="page-banner"></div>
        )}
        {shouldShowTitle && (
          <div class="page-title-block">
            <h1 class={shouldCenterTitle ? 'center-title' : ''}>
              {titleHtml ? <Fragment set:html={titleHtml} /> : pageTitle}
            </h1>
            {descriptionHtml ? (
              <p class="banner-description"><Fragment set:html={descriptionHtml} /></p>
            ) : description && (
              <p class="banner-description">{description}</p>
            )}
          </div>
        )}
        <div class="content-body">
          <slot />
        </div>
      </main>
      <Footer imageLoading={footerImageLoading} />
    </div>
    <script>
      import "../scripts/menu.js";

      document.querySelectorAll('.nav-links a').forEach((link) => {
        link.addEventListener('mousemove', (e) => {
          const rect = link.getBoundingClientRect();
          link.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
          link.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
        });
      });

      document.querySelectorAll('.img-glow-wrap').forEach((el) => {
        el.addEventListener('mousemove', (e) => {
          const rect = el.getBoundingClientRect();
          el.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
          el.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
        });
      });
    </script>
  </body>
  </html>

