---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { pageTitle, titleHtml, shouldCenterTitle, shouldShowTitle = true, footerImageLoading = 'lazy' } = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      const stored = localStorage?.getItem("theme");
      if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
        document.documentElement.dataset.theme = "dark";
      } else {
        document.documentElement.classList.remove("dark");
        document.documentElement.dataset.theme = "light";
      }
      document.documentElement.classList.add("theme-loading");
    </script>
  
    <meta charset="utf-8" />
    <link rel="stylesheet" href="https://use.typekit.net/qck4nvy.css"> <!--- Gill Sans Nova font family from Adobe Fonts -->

    <link rel="preconnect" href="https://fonts.googleapis.com"> <!--- DM Serif Text and Inter fonts from Google Fonts -->
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Text:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

    <link rel="preconnect" href="https://fonts.googleapis.com"> <!--- Ubuntu Mono font from Google Fonts -->
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Ubuntu+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">

    <link rel="icon" type="image/svg+xml" href="/josh-favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LZBBDCSVZC"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LZBBDCSVZC');
  </script> 

  <body>
    <div class="page-wrapper">
      <Header />
      <main class="main-content">
         {shouldShowTitle && (
          <h1 class={shouldCenterTitle ? 'center-title' : ''}>
            {titleHtml ? <Fragment set:html={titleHtml} /> : pageTitle}
          </h1>
        )}
        <slot />
      </main>
      <Footer imageLoading={footerImageLoading} />
    </div>
    <script>
      import "../scripts/menu.js";

      // Wrap the last word of every external link in a no-break span so the
      // icon (applied via .ext-link-tail::after) always stays with the last word.
      const SKIP = ['book-cover-link', 'no-external-icon', 'book-cover-badge',
                    'rb-cover-hover-wrap', 'rb-hardcover-badge', 'btn'];

      document.querySelectorAll('a[target="_blank"]').forEach(link => {
        if (SKIP.some(cls => link.classList.contains(cls))) return;
        if (link.querySelector('.ext-link-tail')) return;

        const walker = document.createTreeWalker(link, NodeFilter.SHOW_TEXT);
        let lastTextNode = null;
        let node;
        while ((node = walker.nextNode())) {
          if (node.textContent.trim()) lastTextNode = node;
        }
        if (!lastTextNode) return;

        const text = lastTextNode.textContent;
        const lastSpaceIdx = text.lastIndexOf(' ');

        const tail = document.createElement('span');
        tail.className = 'ext-link-tail';

        if (lastSpaceIdx >= 0) {
          tail.textContent = text.slice(lastSpaceIdx + 1);
          lastTextNode.textContent = text.slice(0, lastSpaceIdx + 1);
        } else {
          tail.textContent = text;
          lastTextNode.textContent = '';
        }

        link.appendChild(tail);
      });
    </script>
  </body>
  </html>

