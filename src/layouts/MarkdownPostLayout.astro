---
import { Box as BoxIcon, Dna, Rss, Code as CodeIcon, Map as MapIcon, SportShoe, Book } from "lucide-preact";
import { Image } from 'astro:assets';
import { getCollection } from "astro:content";
import joshHeadshot from '../assets/josh-headshot-cropped.jpg';
import BaseLayout from './BaseLayout.astro';
import Panels from '../components/Panels.astro';
import Callout from '../components/Callout.astro';
import BookRating from '../components/BookRating.jsx';
import ImageLightbox from '../components/ImageLightbox.jsx';
import responsiveImagesScript from '../scripts/responsive-images.js?raw';

const { headings = [], slug } = Astro.props;
const { frontmatter } = Astro.props;

const tocHeadings = frontmatter.tags?.includes("books")
  ? [{ depth: 2, slug: "review", text: "Review" }, ...headings]
  : headings;

const pageUrl = Astro.url.href;
const pageTitle = frontmatter.title;
const titleHtml = (frontmatter.tags?.includes('books') && frontmatter.bookTitle)
  ? `Book review: <em>${frontmatter.bookTitleShort ?? frontmatter.bookTitle}</em>`
  : undefined;

const escapeHtml = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
const escapeRegex = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

let descriptionHtml: string | undefined;
if (frontmatter.tags?.includes('books') && frontmatter.bookTitle && frontmatter.description) {
  const safeDesc = escapeHtml(frontmatter.description);
  const safeTitle = escapeHtml(frontmatter.bookTitle);
  const pattern = new RegExp(escapeRegex(safeTitle));
  if (pattern.test(safeDesc)) {
    descriptionHtml = safeDesc.replace(pattern, `<em>${safeTitle}</em>`);
  }
}

const allPosts = await getCollection("blog");

const dateValue = (date: string | Date) => new Date(date).getTime();

const relatedPosts = allPosts
  .filter(post =>
    post.data.title !== frontmatter.title &&
    post.data.tags?.some(tag => frontmatter.tags?.includes(tag))
  )
  .sort((a, b) => {
    const sharedA = a.data.tags?.filter(t => frontmatter.tags?.includes(t)).length ?? 0;
    const sharedB = b.data.tags?.filter(t => frontmatter.tags?.includes(t)).length ?? 0;
    return sharedB - sharedA;
  })
  .slice(0, 3);

const recentPosts = allPosts
  .filter(post => post.data.title !== frontmatter.title)
  .sort((a, b) => dateValue(b.data.pubDate) - dateValue(a.data.pubDate))
  .slice(0, 3);

const postsToShow = relatedPosts.length > 0 ? relatedPosts : recentPosts;
const sectionTitle = relatedPosts.length > 0 ? 'Related Posts' : 'Recent Posts';
const getTagThemeClass = (tag: string) => `tag-theme-${tag.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
const tagIcons = {
  '3dprinting': BoxIcon,
  science: Dna,
  blogging: Rss,
  code: CodeIcon,
  travel: MapIcon,
  triathlon: SportShoe,
  books: Book,
};
const getTagIcon = (tag: string) => tagIcons[tag.toLowerCase() as keyof typeof tagIcons] ?? null;
---
<BaseLayout
  pageTitle={frontmatter.title}
  titleHtml={titleHtml}
  description={frontmatter.description}
  descriptionHtml={descriptionHtml}
  ogImage={slug ? `/social-cards/${slug}.png` : undefined}
  ogType="article"
  showBanner={false}
>

<ImageLightbox client:load />

  <div class="post-header-meta">
  <div class="post-meta">
    <Image src={joshHeadshot} alt="Josh Olivier" width={32} height={32} style="width:2rem;height:2rem;border-radius:50%;flex-shrink:0;pointer-events:none;" data-no-lightbox />
    <span class="post-author">
      {frontmatter.dateModified && new Date(frontmatter.dateModified).toDateString() !== new Date(frontmatter.pubDate).toDateString()
        ? <><a href="/about">{frontmatter.author}</a> updated on {frontmatter.dateModified.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}</>
        : <><a href="/about">{frontmatter.author}</a> on {frontmatter.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}</>
      }
      {' | '}<span class="post-read-time">{frontmatter.readTime} min read</span>
    </span>
  </div>

  <div class="tags">
    {frontmatter.tags.map((tag: string) => {
      const TagIcon = getTagIcon(tag);
      return (
        <a href={`/blog?tag=${tag}`} class={`tag ${getTagThemeClass(tag)}`} role="button">
          {TagIcon ? <TagIcon size="0.9rem" class="tag-icon" aria-hidden="true" /> : <span aria-hidden="true">#</span>}
          <span>{tag}</span>
        </a>
      );
    })}
  </div>

  {frontmatter.tags?.includes("books") && frontmatter.bookTitle && (
    <BookRating client:load bookTitle={frontmatter.bookTitle} />
  )}
  </div>

  <Panels headings={tocHeadings} />



  {frontmatter.tags?.includes("books") && (
    <h2 id="review">Review</h2>
  )}

  {frontmatter.tags?.includes("books") && (
    <Callout type="warning" title="Warning: contains spoilers!" />
  )}

  <slot />

  {frontmatter.tags?.includes("books") && (
    <div>
      → check out my <a href="/bookshelf">bookshelf</a> for more books I've read recently!
    </div>
  )}

  {postsToShow.length > 0 && (
    <div style="margin-top: 2rem;">
      <hr />
      <h2>{sectionTitle}</h2>
      <ul class="blog-list">
        {postsToShow.map(post => (
          <li class="blog-post">
            <a href={`/posts/${post.id}/`} class="post-wrapper post-card-link related-post-link">
              <div class="post-text">
                <div class="post-tag-icons">
                  {post.data.tags?.filter(tag => getTagIcon(tag)).map(tag => {
                    const TagIcon = getTagIcon(tag);
                    return TagIcon ? (
                      <span class={`tag-post-icon ${getTagThemeClass(tag)}`}>
                        <TagIcon size="1.25rem" aria-label={tag} />
                      </span>
                    ) : null;
                  })}
                  <span class="pub-date">
                    {post.data.dateModified && new Date(post.data.dateModified).toDateString() !== new Date(post.data.pubDate).toDateString()
                      ? <>Updated {new Date(post.data.dateModified).toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })}</>
                      : new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })
                    }
                    {' | '}<span class="post-read-time">{post.data.readTime} min</span>
                  </span>
                </div>
                <div class="post-title">
                  {(post.data.tags?.includes('books') && post.data.bookTitle)
                    ? <span>Book review: <em>{post.data.bookTitleShort ?? post.data.bookTitle}</em></span>
                    : post.data.title}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <script set:html={responsiveImagesScript} />

  <script>
    // Wrap blog body images in img-glow-wrap so they get the flashlight+grain hover
    (function () {
      document.querySelectorAll('.blog-body-pic').forEach((img) => {
        if (img.closest('.img-glow-wrap')) return;
        const wrap = document.createElement('div');
        wrap.className = 'img-glow-wrap';
        const cs = getComputedStyle(img);
        const inFigure = img.closest('figure.img-figure');
        wrap.style.display = 'block';
        wrap.style.width = 'fit-content';
        // Match the image's already-computed maxWidth (set by responsive-images script
        // for cached images); falls back to 100% for images not yet loaded — the
        // responsive-images load handler will update it once the image finishes loading.
        wrap.style.maxWidth = img.style.maxWidth || '100%';
        wrap.style.borderRadius = inFigure ? '7px' : cs.borderRadius;
        if (!inFigure) {
          wrap.style.marginTop = cs.marginTop;
          wrap.style.marginBottom = cs.marginBottom;
          img.style.marginTop = '0';
          img.style.marginBottom = '0';
        }
        img.parentNode.insertBefore(wrap, img);
        wrap.appendChild(img);
        wrap.addEventListener('mousemove', (e) => {
          const rect = wrap.getBoundingClientRect();
          wrap.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
          wrap.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .post-description {
    font-size: 1.1rem;
    color: var(--text-muted, var(--text-faint));
    margin-bottom: 2rem;
    font-style: italic;
  }

  .post-header-meta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-meta .post-author,
  .post-meta .post-read-time {
    font-size: 1rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.related-post-link').forEach((el) => {
    el.addEventListener('mousemove', (e) => {
      const me = e as MouseEvent;
      const rect = el.getBoundingClientRect();
      el.style.setProperty('--mouse-x', `${me.clientX - rect.left}px`);
      el.style.setProperty('--mouse-y', `${me.clientY - rect.top}px`);
    });
  });

  const btn = document.getElementById('copy-link-btn');
  const icon = document.getElementById('copy-link-icon');
  const toast = document.getElementById('copy-toast');

  const linkIcon = `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`;
  const checkIcon = `<polyline points="20 6 9 17 4 12"/>`;

  btn?.addEventListener('click', async () => {
    if (!icon || !toast) return;
    await navigator.clipboard.writeText(window.location.href);
    icon.innerHTML = checkIcon;
    btn.classList.add('copied');
    toast.classList.add('show');
    setTimeout(() => {
      icon.innerHTML = linkIcon;
      btn.classList.remove('copied');
      toast.classList.remove('show');
    }, 2000);
  });
</script>