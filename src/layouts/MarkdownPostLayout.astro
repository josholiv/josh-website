---
import { User, Calendar, Timer, Cog as CogIcon, Dna, Rss, Code as CodeIcon, Map as MapIcon, SportShoe, Book, LibraryBig } from "lucide-preact";
import { getCollection } from "astro:content";
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import Callout from '../components/Callout.astro';
import BookRating from '../components/BookRating.jsx';
import ImageLightbox from '../components/ImageLightbox.jsx';
import responsiveImagesScript from '../scripts/responsive-images.js?raw';

const { headings = [] } = Astro.props;
const { frontmatter } = Astro.props;

const pageUrl = Astro.url.href;
const pageTitle = frontmatter.title;
const titleHtml = (frontmatter.tags?.includes('books') && frontmatter.bookTitle)
  ? `Book review: <em>${frontmatter.bookTitleShort ?? frontmatter.bookTitle}</em>`
  : undefined;

const allPosts = await getCollection("blog");

const dateValue = (date: string | Date) => new Date(date).getTime();

const relatedPosts = allPosts
  .filter(post =>
    post.data.title !== frontmatter.title &&
    post.data.tags?.some(tag => frontmatter.tags?.includes(tag))
  )
  .sort((a, b) => {
    const sharedA = a.data.tags?.filter(t => frontmatter.tags?.includes(t)).length ?? 0;
    const sharedB = b.data.tags?.filter(t => frontmatter.tags?.includes(t)).length ?? 0;
    return sharedB - sharedA;
  })
  .slice(0, 3);

const recentPosts = allPosts
  .filter(post => post.data.title !== frontmatter.title)
  .sort((a, b) => dateValue(b.data.pubDate) - dateValue(a.data.pubDate))
  .slice(0, 3);

const postsToShow = relatedPosts.length > 0 ? relatedPosts : recentPosts;
const sectionTitle = relatedPosts.length > 0 ? 'Related Posts' : 'Recent Posts';
const getTagThemeClass = (tag: string) => `tag-theme-${tag.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
const tagIcons = {
  '3dprinting': CogIcon,
  science: Dna,
  blogging: Rss,
  code: CodeIcon,
  travel: MapIcon,
  triathlon: SportShoe,
  books: Book,
};
const getTagIcon = (tag: string) => tagIcons[tag.toLowerCase() as keyof typeof tagIcons] ?? null;
---
<BaseLayout pageTitle={frontmatter.title} titleHtml={titleHtml}>

<ImageLightbox client:load />

<hr class="rainbow-hr">

  <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">

    <div class="post-author" style="display: inline-flex; align-items: center; gap: 0.3rem;">
      <User size="1rem" />
      <a href="/about">{frontmatter.author}</a>
    </div>

    <div class="pub-date" style="display: inline-flex; align-items: center; gap: 0.3rem;">
      <Calendar size="1rem" />
      {frontmatter.pubDate.toLocaleDateString('en-US', { 
        year: 'numeric', 
        month: 'long', 
        timeZone: 'UTC'})}
    </div>

    <div class="post-read-time" style="display: inline-flex; align-items: center; gap: 0.3rem;">
      <Timer size="1rem" />
      <i>{frontmatter.readTime} minute read</i>
    </div>
  </div>

  <div style="margin-bottom: 2rem" class="tags">
    {frontmatter.tags.map((tag: string) => {
      const TagIcon = getTagIcon(tag);
      return (
        <a href={`/blog?tag=${tag}`} class={`tag ${getTagThemeClass(tag)}`} role="button">
          {TagIcon ? <TagIcon size="0.9rem" class="tag-icon" aria-hidden="true" /> : <span aria-hidden="true">#</span>}
          <span>{tag}</span>
        </a>
      );
    })}
  </div>

  <!-- ─── Share ─── -->
  <div style="margin-bottom: 2rem;">
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">

      <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`}
        target="_blank" class="btn share-btn" aria-label="Share on LinkedIn" title="Share on LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(pageTitle)}`}
        target="_blank" class="btn share-btn" aria-label="Share on Reddit" title="Share on Reddit">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
        </svg>
      </a>

      <a href={`https://bsky.app/intent/compose?text=${encodeURIComponent(pageTitle + ' ' + pageUrl)}`}
        target="_blank" class="btn share-btn" aria-label="Share on Bluesky" title="Share on Bluesky">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
        </svg>
      </a>

      <button class="btn" id="copy-link-btn" aria-label="Copy link" title="Copy link">
        <svg id="copy-link-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
      </button>

    </div>
  </div>

  <TOC headings={headings} />

    {frontmatter.tags?.includes("books") && (
    <Callout type="warning" title="Warning: contains spoilers!" />
  )}

  {frontmatter.tags?.includes("books") && frontmatter.bookTitle && (
    <BookRating client:load bookTitle={frontmatter.bookTitle} />
  )}



  <slot />

  {frontmatter.tags?.includes("books") && (
    <div>
      <i>→ see more books I've read on my <a href="/bookshelf">bookshelf</a></i>
    </div>
  )}

  {postsToShow.length > 0 && (
    <div style="margin-top: 2rem;">
      <hr />
      <h2>{sectionTitle}</h2>
      <ul class="blog-list">
        {postsToShow.map(post => (
          <li class="blog-post">
            <a href={`/posts/${post.id}/`} class="post-wrapper post-card-link">
              {post.data.image?.url && (
                <div class="blog-thumbnail-wrapper">
                  <img
                    src={post.data.image.url}
                    alt={post.data.image.alt || post.data.title}
                    class="blog-thumbnail"
                  />
                </div>
              )}
              <div class="post-text">
                <div class="post-title">
                  {(post.data.tags?.includes('books') && post.data.bookTitle)
                    ? <span>Book review: <em>{post.data.bookTitleShort ?? post.data.bookTitle}</em></span>
                    : post.data.title}
                </div>
                <div style="display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;">
                  <span class="pub-date icon-container-inline">
                    <Calendar size="1rem" />
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                      month: 'long',
                      year: 'numeric',
                      timeZone: 'UTC',
                    })}
                  </span>
                  <span style="color: var(--text-faint);">|</span>
                  <span class="post-read-time icon-container-inline">
                    <Timer size="1rem" />
                    {post.data.readTime} min
                  </span>
                </div>
                <div class="tags" style="display: flex; flex-wrap: wrap; gap: 0.6rem;">
                  {post.data.tags?.map(tag => {
                    const TagIcon = getTagIcon(tag);
                    return (
                      <span class={`tag-blogsorter ${getTagThemeClass(tag)}`}>
                        {TagIcon ? <TagIcon size="0.9rem" class="tag-icon" aria-hidden="true" /> : <span aria-hidden="true">#</span>}
                        <span>{tag}</span>
                      </span>
                    );
                  })}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  ← <a href="/blog">back to blog</a>

  <div id="copy-toast">Link copied!</div>

  <script set:html={responsiveImagesScript} />
</BaseLayout>

<style>
  a.share-btn::after {
    display: none;
  }

  a.share-btn:visited {
    color: var(--btn-text);
  }

  a.share-btn:visited:hover {
    color: var(--btn-text-hover);
  }

  #copy-link-btn.copied {
    color: var(--green-400);
    box-shadow: 0 2px 0 0 var(--green-400);
  }

  #copy-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(1rem);
    background-color: var(--bg-secondary);
    border: 1px solid var(--green-400);
    color: var(--green-400);
    padding: 0.5rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  #copy-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Lightbox styles */
  :global(.lightbox-overlay) {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  :global(.lightbox-content) {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.lightbox-image) {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 0px;
  }

  :global(.lightbox-close) {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.6);
    border: none;
    color: white;
    font-size: 1.8rem;
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    z-index: 1001;
  }

  :global(.lightbox-close:hover) {
    background-color: rgba(0, 0, 0, 0.8);
  }

  :global(article img),
  :global(.prose img) {
    transition: opacity 0.2s ease;
  }

  :global(article img:hover),
  :global(.prose img:hover) {
    opacity: 0.9;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes zoomIn {
    from {
      transform: scale(0.9);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script>
  const btn = document.getElementById('copy-link-btn');
  const icon = document.getElementById('copy-link-icon');
  const toast = document.getElementById('copy-toast');

  const linkIcon = `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`;
  const checkIcon = `<polyline points="20 6 9 17 4 12"/>`;

  btn?.addEventListener('click', async () => {
    if (!icon || !toast) return;
    await navigator.clipboard.writeText(window.location.href);
    icon.innerHTML = checkIcon;
    btn.classList.add('copied');
    toast.classList.add('show');
    setTimeout(() => {
      icon.innerHTML = linkIcon;
      btn.classList.remove('copied');
      toast.classList.remove('show');
    }, 2000);
  });
</script>