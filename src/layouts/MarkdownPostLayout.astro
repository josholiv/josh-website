---
import { User, Calendar, Timer } from "lucide-preact";

import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>

  <div class="wave-container">
    <div class="wave wave-small"></div>
    <div class="wave wave-big"></div>
  </div>

  <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2rem;">
    <span class="pub-date" style="display: inline-flex; align-items: center; gap: 0.3rem;">
      <Calendar size="1rem" />
      {frontmatter.pubDate.toLocaleDateString('en-US', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric', 
        timeZone: 'UTC'})}
    </span>

    <span style="color: var(--text-faint);">|</span>

    <span class="post-author" style="display: inline-flex; align-items: center; gap: 0.3rem;">
      <User size="1rem" />
      {frontmatter.author}
    </span>

    <span style="color: var(--text-faint);">|</span>

    <span class="post-read-time" style="display: inline-flex; align-items: center; gap: 0.3rem;">
      <Timer size="1rem" />
      {frontmatter.readTime} minute read
    </span>
  </div>

  <div style="margin-bottom: 2rem" class="tags">
    {frontmatter.tags.map((tag: string) => (
      <a href={`/blog?tag=${tag}`} class="tag" role="button">
      #{tag}
     </a>
    ))}
  </div>

<hr>

  <slot />
</BaseLayout>