---
import {
  Info, Check, AlertTriangle, X, Lightbulb, NotebookPen,
  ClipboardList, Flame, Bug, Quote, Code, FlaskConical, HelpCircle,
  ChevronRight, Zap
} from "lucide-preact";

const variants = {
  info:      { icon: Info,          label: "Info",     class: "callout-info" },
  success:   { icon: Check,         label: "Success",  class: "callout-success" },
  warning:   { icon: AlertTriangle, label: "Warning",  class: "callout-warning" },
  danger:    { icon: Zap,           label: "Danger",   class: "callout-danger" },
  tip:       { icon: Lightbulb,     label: "Tip",      class: "callout-tip" },
  note:      { icon: NotebookPen,   label: "Note",     class: "callout-note" },
  check:     { icon: Check,         label: "Check",    class: "callout-success" },
  done:      { icon: Check,         label: "Done",     class: "callout-success" },
  hint:      { icon: Lightbulb,     label: "Hint",     class: "callout-tip" },
  important: { icon: Flame,         label: "Important",class: "callout-tip" },
  caution:   { icon: AlertTriangle, label: "Caution",  class: "callout-warning" },
  attention: { icon: AlertTriangle, label: "Attention",class: "callout-warning" },
  error:     { icon: Zap,           label: "Error",    class: "callout-danger" },
  failure:   { icon: X,             label: "Failure",  class: "callout-danger" },
  fail:      { icon: X,             label: "Fail",     class: "callout-danger" },
  missing:   { icon: X,             label: "Missing",  class: "callout-danger" },
  todo:      { icon: ClipboardList, label: "Todo",     class: "callout-todo" },
  code:      { icon: Code,          label: "Code",     class: "callout-code" },
  example:   { icon: FlaskConical,  label: "Example",  class: "callout-example" },
  abstract:  { icon: ClipboardList, label: "Abstract", class: "callout-abstract" },
  summary:   { icon: ClipboardList, label: "Summary",  class: "callout-abstract" },
  tldr:      { icon: ClipboardList, label: "TL;DR",    class: "callout-abstract" },
  quote:     { icon: Quote,         label: "Quote",    class: "callout-quote" },
  cite:      { icon: Quote,         label: "Cite",     class: "callout-quote" },
  bug:       { icon: Bug,           label: "Bug",      class: "callout-bug" },
  faq:       { icon: HelpCircle,    label: "FAQ",      class: "callout-faq" },
  question:  { icon: HelpCircle,    label: "Question", class: "callout-faq" },
  help:      { icon: HelpCircle,    label: "Help",     class: "callout-faq" },
};

interface Props {
  type?: keyof typeof variants;
  title?: string;
  icon?: any;
  collapsible?: boolean;
  defaultOpen?: boolean;
}

const { type = "info", title, icon, collapsible = false, defaultOpen = false } = Astro.props;
const variant = variants[type];
const Icon = icon ?? variant.icon;
const hasContent = Astro.slots.has('default');
---

<div
  class={`blockquote ${variant.class} ${collapsible ? 'callout-collapsible' : ''}`}
  data-collapsible={collapsible}
  data-open={collapsible ? String(defaultOpen) : undefined}
>
  <div class={`callout-title ${!hasContent && !collapsible ? 'callout-title-only' : ''} ${collapsible ? 'callout-title-clickable' : ''}`}>
    <Icon size={"1.1rem"} />
    <span style="display: flex; align-items: center; gap: 0.4rem;">
      <slot name="title">{title ?? variant.label}</slot>
      {collapsible && (
        <span class="callout-chevron">
          <ChevronRight size={"1.1rem"} />
        </span>
      )}
    </span>
  </div>

  {hasContent && (
    <div class="callout-body">
      <div class="callout-body-inner">
        <slot />
      </div>
    </div>
  )}
</div>

<style>
  .callout-title-only {
    margin-bottom: 0;
  }

  .callout-title-clickable {
    cursor: pointer;
    user-select: none;
    margin-bottom: 0;
  }

  .callout-title :global(svg) {
    flex: 0 0 auto;
  }

  .callout-title > span:not(.callout-chevron) {
    flex: 1 1 auto;
    min-width: 0;
  }

  .callout-chevron {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    transition: transform 0.2s ease;
    transform: rotate(90deg);
  }

  [data-open="false"] .callout-chevron {
    transform: rotate(0deg);
  }

  .callout-body {
    overflow: hidden;
    transition: height 0.25s ease-in-out;
    height: auto;
  }

  .callout-collapsible[data-open="false"] .callout-body {
    height: 0;
  }

  .callout-body-inner {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    line-height: 1.4;
  }
</style>

<script>
  document.querySelectorAll('[data-collapsible="true"]').forEach(callout => {
    const titleEl = callout.querySelector('.callout-title-clickable') as HTMLElement | null;
    const body = callout.querySelector('.callout-body') as HTMLElement | null;
    if (!titleEl || !body) return;

    const setClosed = () => {
      const bodyHeight = body.getBoundingClientRect().height;
      body.style.height = `${bodyHeight}px`;
      body.offsetHeight; // force a layout flush before changing height
      requestAnimationFrame(() => {
        body.style.height = '0px';
      });
    };

    const setOpen = () => {
      const bodyHeight = body.scrollHeight;
      body.style.height = `${bodyHeight}px`;
      const onTransitionEnd = () => {
        body.style.height = 'auto';
        body.removeEventListener('transitionend', onTransitionEnd);
      };
      body.addEventListener('transitionend', onTransitionEnd);
    };

    if (callout.getAttribute('data-open') === 'true') {
      body.style.height = 'auto';
    } else {
      body.style.height = '0px';
    }

    titleEl.addEventListener('click', () => {
      const isOpen = callout.getAttribute('data-open') === 'true';
      if (isOpen) {
        setClosed();
      } else {
        setOpen();
      }
      callout.setAttribute('data-open', String(!isOpen));
    });
  });
</script>