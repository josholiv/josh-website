---
const pathname = Astro.url.pathname;
import { Home, Info, GraduationCap, Rss, Contact } from "lucide-preact";
---
<div class="nav-links">

<a href="/" class={`${pathname === "/" ? "active" : ""}`}>
  <span class="icon-container">
    <Home size={"1rem"} class="nav-icon"/>
    &nbsp;
    Home<span style={{color: "var(--text-muted)"}}></span>
  </span>
</a>

<a href="/about" class={`${pathname === "/about" || pathname === "/about/" ? "active" : ""}`}>
  <span class="icon-container">
    <Info size={"1rem"} class="nav-icon"/>
    &nbsp;
    About
  </span>
</a>

<a href="/cv" class={`${pathname === "/cv" || pathname === "/cv/" ? "active" : ""}`}>
  <span class="icon-container">
    <GraduationCap size={"1rem"} class="nav-icon"/>
    &nbsp;
    CV
  </span>
</a>

<a href="/blog" class={`${pathname.startsWith("/blog") || pathname.startsWith("/posts") || pathname.startsWith("/tags") ? "active" : ""}`}>
  <span class="icon-container">
    <Rss size={"1rem"} class="nav-icon"/>
    &nbsp;
    Blog
  </span>
</a>

<a href="/contact" class={`${pathname === "/contact" || pathname === "/contact/" ? "active" : ""}`}>
  <span class="icon-container">
    <Contact size={"1rem"} class="nav-icon"/>
    &nbsp;
    Contact
  </span>
</a>

</div>
