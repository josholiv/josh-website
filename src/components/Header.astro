---
import Hamburger from './Hamburger.astro';
import Navigation from './Navigation.astro';
import ThemeIcon from './ThemeIcon.astro';
---

<header>
  <nav>
    <Hamburger />
    <Navigation />
  </nav>
  <div class="theme-toggle-wrapper">
    <ThemeIcon />
  </div>
</header>

<style>
  .theme-toggle-wrapper {
    position: fixed;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 100;
  }
</style>