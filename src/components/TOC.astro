---
import { ChevronRight, List } from 'lucide-preact';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
  defaultOpen?: boolean;
}

const { headings = [], defaultOpen = false } = Astro.props;

type HeadingGroup = { h2: Heading; h3s: Heading[] };
const grouped: HeadingGroup[] = [];
for (const h of headings.filter(h => h.depth === 2 || h.depth === 3)) {
  if (h.depth === 2) {
    grouped.push({ h2: h, h3s: [] });
  } else if (grouped.length > 0) {
    grouped[grouped.length - 1].h3s.push(h);
  }
}
---

<div class="toc-panel">
  <a href="/" class="toc-site-title">
    <span class="toc-site-title-main">josholivier</span><span class="toc-site-title-domain">.com</span>
  </a>

  <nav class="toc" id="toc" data-open={String(defaultOpen)}>
    <button class="toc-title" id="toc-toggle">
      <List size="0.9rem" />
      On this page
      <span class="toc-chevron">
        <ChevronRight size="0.9rem" />
      </span>
    </button>
    <div class="toc-body">
      <div class="toc-body-inner">
        <ul id="toc-list">
          {grouped.map(({ h2, h3s }) => (
            <li class="toc-item">
              <a href={`#${h2.slug}`}>
                {h2.text}
              </a>
              {h3s.length > 0 && (
                <ul class="toc-sublist">
                  {h3s.map(h3 => (
                    <li class="toc-subitem">
                      <a href={`#${h3.slug}`}>{h3.text}</a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </nav>
</div>

<style>
  .toc-site-title {
    display: none;
    font-family: "DM Serif Text", serif;
    font-size: 1.7rem;
    font-weight: 400;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    color: var(--text-heading);
    margin-bottom: 3rem;
    margin-left: 0.3rem;
  }

  .toc-site-title-main {
    color: inherit;
  }

  .toc-site-title-domain {
    color: var(--text-faint);
  }

  .toc-site-title:hover,
  .toc-site-title:active,
  .toc-site-title:visited,
  .toc-site-title:visited:hover,
  .toc-site-title:focus,
  .toc-site-title:focus-visible {
    color: var(--text-heading);
  }

  @media (min-width: 1300px) {
    .toc-panel {
      position: fixed;
      top: 2rem;
      left: calc(50% - 35ch - 9.75rem - 8rem);
      width: 14rem;
      display: flex;
      flex-direction: column;
    }

    .toc-site-title {
      display: block;
    }

    :global(#toc) {
      position: static;
      top: auto;
      left: auto;
      width: auto;
      margin-bottom: 0;
      max-height: calc(100vh - 2rem - 1.45rem - 0.5rem);
      overflow-y: auto;
    }
  }
</style>

<script>
  // Set open state based on screen width; wide = open, mobile = closed.
  const toc = document.getElementById('toc');

  function applyDefaultOpen() {
    if (!toc) return;
    toc.setAttribute('data-open', String(window.innerWidth >= 1300));
  }

  applyDefaultOpen();
  window.addEventListener('resize', applyDefaultOpen, { passive: true });

  // Collapse toggle
  const toggle = document.getElementById('toc-toggle');

  toggle?.addEventListener('click', () => {
    if (!toc) return;
    const isOpen = toc.getAttribute('data-open') === 'true';
    toc.setAttribute('data-open', String(!isOpen));
  });

  // Active heading highlight
  const headingEls = Array.from(document.querySelectorAll('main h2, main h3')) as HTMLElement[];

  // When the user clicks a TOC link we pin that heading as active and
  // keep it pinned until they make a deliberate scroll gesture.
  let pinnedId: string | null = null;

  function clearPin() {
    if (!pinnedId) return;
    pinnedId = null;
    pickActive();
  }

  // Use event delegation so it works for both server-rendered and
  // dynamically auto-populated links.
  document.getElementById('toc-list')?.addEventListener('click', (e) => {
    const a = (e.target as Element).closest('a');
    if (!a) return;
    const href = a.getAttribute('href');
    if (href?.startsWith('#')) {
      pinnedId = href.slice(1);
      setActive(pinnedId);
    }
  });

  // Release the pin only on genuine user scroll input, not the
  // programmatic scroll caused by the anchor jump.
  window.addEventListener('wheel', clearPin, { passive: true });
  window.addEventListener('touchstart', clearPin, { passive: true });
  window.addEventListener('keydown', (e) => {
    if (['ArrowUp','ArrowDown','PageUp','PageDown',' ','Home','End'].includes(e.key)) clearPin();
  });

  function setActive(id: string | null) {
    document.querySelectorAll('#toc-list a').forEach(a => a.classList.remove('toc-active'));
    if (id) {
      document.querySelector(`#toc-list a[href="#${CSS.escape(id)}"]`)?.classList.add('toc-active');
    }
  }

  function pickActive() {
    // If the user clicked a TOC link, keep that item highlighted until
    // they scroll deliberately.
    if (pinnedId) {
      setActive(pinnedId);
      return;
    }

    // Special case: at the very bottom of the page, the last heading wins.
    const atBottom =
      window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 10;
    if (atBottom && headingEls.length > 0) {
      setActive(headingEls[headingEls.length - 1].id);
      return;
    }

    // Otherwise, the active heading is the last one whose top edge has
    // scrolled above a small threshold near the top of the viewport.
    const threshold = 120;
    let activeId: string | null = headingEls[0]?.id ?? null;
    for (const h of headingEls) {
      if (h.getBoundingClientRect().top <= threshold) {
        activeId = h.id;
      }
    }
    setActive(activeId);
  }

  window.addEventListener('scroll', pickActive, { passive: true });
  window.addEventListener('resize', pickActive, { passive: true });

  // Auto-populate headings if none were server-rendered
  const list = document.getElementById('toc-list');

  if (list && list.children.length === 0) {
    const headings = Array.from(document.querySelectorAll('main h2, main h3'));
    let currentH2Li: HTMLLIElement | null = null;
    let currentSublist: HTMLUListElement | null = null;

    headings.forEach(h => {
      if (!h.id) {
        h.id = h.textContent
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-');
      }

      if (h.tagName === 'H2') {
        const li = document.createElement('li');
        li.className = 'toc-item';

        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent;

        li.appendChild(a);
        list.appendChild(li);
        currentH2Li = li;
        currentSublist = null;
      } else if (h.tagName === 'H3' && currentH2Li) {
        if (!currentSublist) {
          currentSublist = document.createElement('ul');
          currentSublist.className = 'toc-sublist';
          currentH2Li.appendChild(currentSublist);
        }

        const li = document.createElement('li');
        li.className = 'toc-subitem';

        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent;

        li.appendChild(a);
        currentSublist.appendChild(li);
      }
    });
  }

  // Re-run after auto-populating so newly added headings are immediately highlighted.
  pickActive();
</script>
